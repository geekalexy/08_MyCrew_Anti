  "text": "<file_operations>\n[\n  {\n    \"action\": \"write\",\n    \"type\": \"output\",\n    \"path\": \"src/core/resource-manager.service.ts\",\n    \"content\": \"import { Injectable, Logger } from '@nestjs/common';\\nimport { ConfigService } from '@nestjs/config';\\n\\n// 가상 외부 라이브러리 및 에러 타입\\n// 실제 환경에서는 별도 파일로 분리되어야 합니다.\\nexport class TimeoutError extends Error {\\n  constructor(message?: string) {\\n    super(message);\\n    this.name = 'TimeoutError';\\n  }\\n}\\n\\nexport async function acquireResource(resourceId: string, options: { timeout: number }): Promise<any> {\\n  // 실제 시스템의 리소스 관리자와 상호작용하는 로직을 모의(mock)합니다.\\n  // 현실적인 시뮬레이션을 위해 무작위로 성공 또는 타임아웃을 발생시킵니다.\\n  return new Promise((resolve, reject) => {\\n    const timer = setTimeout(() => {\\n      reject(new TimeoutError(`Request for resource ${resourceId} timed out after ${options.timeout}ms.`));\\n    }, options.timeout);\\n\\n    // 0~40초 사이의 가상 작업 시간 시뮬레이션\\n    const workTime = Math.random() * 40000;\\n    if (workTime < options.timeout) {\\n        setTimeout(() => {\\n            clearTimeout(timer);\\n            resolve({ id: resourceId, acquiredAt: new Date() });\\n        }, workTime);\\n    }\\n  });\\n}\\n\\ninterface RequestResourceOptions {\\n  timeoutMs: number;\\n  maxRetries: number;\\n  initialBackoffMs: number;\\n  maxBackoffMs: number;\\n}\\n\\n@Injectable()\\nexport class ResourceManagerService {\\n  private readonly logger = new Logger(ResourceManagerService.name);\\n\\n  constructor(private configService: ConfigService) {}\\n\\n  /**\\n   * 요청한 자원을 획득합니다. Timeout 및 Exponential Backoff with Jitter 재시도 로직이 적용됩니다.\\n   * @param resourceId 요청할 자원의 ID\\n   * @param agentId 요청하는 에이전트의 ID\\n   * @returns 획득한 자원 객체\\n   */\\n  async requestResource(resourceId: string, agentId: string): Promise<any> {\\n    const options: RequestResourceOptions = {\\n      timeoutMs: this.configService.get<number>('resource.requestTimeoutMs', 30000),\\n      maxRetries: this.configService.get<number>('resource.maxRetries', 5),\\n      initialBackoffMs: this.configService.get<number>('resource.initialBackoffMs', 100),\\n      maxBackoffMs: this.configService.get<number>('resource.maxBackoffMs', 5000),\\n    };\\n\\n    let attempt = 0;\\n    let backoff = options.initialBackoffMs;\\n\\n    while (attempt <= options.maxRetries) {\\n      try {\\n        this.logger.log({\\n          message: `Attempting to acquire resource`,\\n          resourceId,\\n          agentId,\\n          attempt: attempt + 1,\\n          timeout: options.timeoutMs,\\n        });\\n        // TODO: metrics.increment('resource_request_attempts_total', { resourceId });\\n\\n        const resource = await acquireResource(resourceId, { timeout: options.timeoutMs });\\n        \\n        this.logger.log({\\n          message: `Successfully acquired resource`,\\n          resourceId,\\n          agentId,\\n          attempt: attempt + 1,\\n        });\\n        // TODO: metrics.increment('resource_request_success_total', { resourceId });\\n        \\n        return resource;\\n\\n      } catch (error) {\\n        if (error instanceof TimeoutError) {\\n          // TODO: metrics.increment('resource_request_timeouts_total', { resourceId });\\n          \\n          if (attempt === options.maxRetries) {\\n            this.logger.error({\\n              message: `Failed to acquire resource after max retries due to timeout`,\\n              resourceId,\\n              agentId,\\n              maxRetries: options.maxRetries,\\n            });\\n            // TODO: metrics.increment('resource_request_failure_total', { resourceId, reason: 'timeout' });\\n            throw new Error(`Failed to acquire resource ${resourceId} for agent ${agentId} after ${options.maxRetries} retries.`);\\n          }\\n          \\n          const jitter = Math.random() * backoff * 0.5; // 0% to 50% jitter\\n          const delay = Math.min(backoff + jitter, options.maxBackoffMs);\\n\\n          this.logger.warn({\\n            message: `Timeout acquiring resource. Retrying after delay.`,\\n            resourceId,\\n            agentId,\\n            attempt: attempt + 1,\\n            delay,\\n          });\\n          // TODO: metrics.increment('resource_request_retries_total', { resourceId });\\n          \\n          await new Promise(res => setTimeout(res, delay));\\n          backoff *= 2; // Exponential backoff\\n          attempt++;\\n\\n        } else {\\n          this.logger.error({\\n            message: `Failed to acquire resource due to non-retriable error`,\\n            resourceId,\\n            agentId,\\n            error: error.message,\\n          });\\n          // TODO: metrics.increment('resource_request_failure_total', { resourceId, reason: 'non_retriable_error' });\\n          throw error; // 재시도 불가능한 에러는 즉시 전파\\n        }\\n      }\\n    }\\n  }\\n}\\n\"\n  },\n  {\n    \"action\": \"write\",\n    \"type\": \"output\",\n    \"path\": \"docs/architecture/deadlock-detection-system-v2.md\",\n    \"content\": \"# 아키텍처 설계: 교착 상태 감지 및 방지 시스템 v2\\n\\n**문서 ID**: `ARCH-DDS-V2`\\n**작성자**: DEV_FULLSTACK\\n**수정일**: 2024-05-07\\n**관련 인시던트**: `INC-202405-001`\\n\\n---\\n\\n## 1. 개요\\n\\n본 문서는 에이전트 간 자원 요청 시 발생할 수 있는 교착 상태(Deadlock)를 실시간으로 감지하고, 운영자에게 경고하며, 필요시 자동으로 복구하기 위한 시스템 아키텍처 v2를 정의합니다. 기존 v1 설계의 단일 장애점(SPOF) 및 확장성 문제를 해결하고, 관측 가능성을 대폭 향상시키는 것을 목표로 합니다.\\n\\n## 2. 핵심 개선 사항 (v1 대비)\\n\\n- **상태 관리 중앙화**: 인스턴스 메모리 기반의 상태 관리를 버리고, **Redis**를 사용하여 자원 점유 및 대기 상태를 중앙에서 관리합니다. 이를 통해 Agent Manager를 Stateless하게 만들어 확장성과 장애 복원력을 확보합니다.\\n- **이벤트 기반 실시간 탐지**: 주기적인 스캔 방식에서 벗어나, 자원 요청/해제 이벤트 발생 시마다 실시간으로 의존성 그래프를 갱신하고 교착 상태(Cycle)를 탐지하는 이벤트 기반 아키텍처를 채택합니다.\\n- **구체적인 경고 및 대응 정책**: 경고 payload를 표준화하고, 자동 롤백을 위한 '희생양(victim)' 선택 정책을 명확히 정의합니다.\\n- **시각화 및 모니터링 강화**: 교착 상태 발생 시 의존성 그래프를 시각화하고, 관련 지표를 Prometheus로 수집하여 Grafana 대시보드에서 모니터링할 수 있도록 설계합니다.\\n\\n## 3. 시스템 아키텍처\\n\\n",
