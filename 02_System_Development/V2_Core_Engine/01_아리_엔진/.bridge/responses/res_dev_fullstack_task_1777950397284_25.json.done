  "text": "```yaml\n# automations/stabilization/nova_to_pico_handoff.yml\n# Description: Stabilization protocol configuration for the Nova to Pico handoff rule.\n# Status: Monitoring Activated\n# Initiated by: DEV_FULLSTACK\n# Date: 2026-05-15\n\nrule_name: \"nova_to_pico_handoff\"\nstatus: STABILIZATION_IN_PROGRESS\n\nstabilization_protocol:\n  # 1. 모니터링 연장 (Extended Monitoring)\n  monitoring:\n    description: \"자동화 규칙의 안정성 및 성능을 평가하기 위해 14일간 집중 모니터링을 활성화합니다.\"\n    duration_days: 14\n    start_date: \"2026-05-15T09:00:00Z\"\n    end_date: \"2026-05-29T09:00:00Z\"\n    metrics_to_track:\n      - \"handoff_success_count\"\n      - \"handoff_failure_count\"\n      - \"execution_latency_ms\"\n      - \"manual_intervention_required\"\n\n  # 2. 핵심 성과 지표 (Key Performance Indicators)\n  kpi:\n    description: \"안정화 완료를 판단하기 위한 구체적인 성공 기준을 정의합니다.\"\n    targets:\n      - metric: \"success_rate\"\n        description: \"전체 핸드오프 시도 중 성공 비율\"\n        threshold: \">= 99.5%\"\n      - metric: \"average_latency_ms\"\n        description: \"핸드오프 평균 처리 시간\"\n        threshold: \"< 500\"\n      - metric: \"error_rate\"\n        description: \"전체 핸드오프 시도 중 실패 비율\"\n        threshold: \"< 0.5%\"\n\n  # 3. 알림 설정 (Notification Configuration)\n  notifications:\n    description: \"KPI 미달 또는 시스템 오류 발생 시 지정된 채널로 즉시 알림을 전송합니다.\"\n    channels:\n      - name: \"on_failure\"\n        description: \"실패 이벤트 발생 시 즉시 알림\"\n        type: \"slack\"\n        target: \"#dev-alerts\"\n        recipient: \"@oncall_sre\"\n        condition: \"handoff_failure_count >= 1\"\n      - name: \"on_kpi_miss\"\n        description: \"일일 KPI 목표 미달 시 요약 리포트 발송\"\n        type: \"slack\"\n        target: \"#dev-team\"\n        recipient: \"@dev_fullstack\"\n        frequency: \"daily\"\n        condition: \"daily_success_rate < 99.5%\"\n\n  # 4. 완료 조건 (Completion Criteria)\n  completion_criteria:\n    description: \"모니터링 기간 동안 아래 조건을 모두 충족해야 안정화 단계가 완료됩니다.\"\n    conditions:\n      - \"모니터링 기간(14일) 동안 모든 KPI 목표를 지속적으로 달성\"\n      - \"수동 개입(Manual Intervention) 발생 횟수 0회\"\n      - \"DEV_ADVISOR 및 CTO 최종 승인 완료\"\n    sign_off_required_by:\n      - \"dev_advisor\"\n      - \"cto_luca\"\n\n```\n\n<next_sprint>\n{\n  \"title\": \"자동화 규칙 안정화 모니터링 설정 검증 요청\",\n  \"content\": \"DEV_ADVISOR의 검토 의견에 따라 'nova_to_pico_handoff' 자동화 규칙의 안정화 프로토콜을 시스템에 적용했습니다. 생성된 설정 파일(`automations/stabilization/nova_to_pico_handoff.yml`)을 기반으로 모니터링 및 알림 시스템이 정상적으로 연동되었는지 검증해 주십시오.\",\n  \"assignee\": \"dev_qa\"\n}\n</next_sprint>",
