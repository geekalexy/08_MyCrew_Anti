  "text": "```python\n# FILE: src/pipelines/content_validator.py\n# DESC: 콘텐츠 파이프라인 기획 단계 진입 전 '타겟 페르소나' 필드 검증 로직\n\nclass Task:\n    \"\"\"\n    칸반 보드의 태스크를 모방한 클래스입니다.\n    \"\"\"\n    def __init__(self, task_id, status='TODO', pipeline_stage='PRE_PLANNING', target_persona=None, content=\"\"):\n        self.id = task_id\n        self.status = status\n        self.pipeline_stage = pipeline_stage\n        self.target_persona = target_persona\n        self.content = content\n\n    def __repr__(self):\n        return (f\"Task(id='{self.id}', status='{self.status}', \"\n                f\"pipeline_stage='{self.pipeline_stage}', \"\n                f\"target_persona='{self.target_persona}')\")\n\n\ndef process_to_planning_stage(task: Task) -> Task:\n    \"\"\"\n    태스크를 기획(Planning) 단계로 넘기기 전, 필수 필드를 검증합니다.\n    - '타겟 페르소나' 필드가 비어있을 경우, 상태를 'NEEDS_DEFINITION'으로 변경합니다.\n    - 필드가 채워져 있을 경우, 다음 단계인 'PLANNING'으로 진행하고 상태를 'IN_PROGRESS'로 변경합니다.\n    \"\"\"\n    print(f\"[{task.id}] 기획 단계 진입 검증 시작...\")\n    print(f\"[{task.id}] 현재 상태: {task.status}, 현재 파이프라인: {task.pipeline_stage}\")\n\n    # '타겟 페르소나' 필드 검증 로직\n    if not task.target_persona:\n        print(f\"[{task.id}] >> 검증 실패: '타겟 페르소나'가 정의되지 않았습니다.\")\n        task.status = 'NEEDS_DEFINITION'\n        print(f\"[{task.id}] >> 상태 변경: {task.status}\")\n    else:\n        print(f\"[{task.id}] >> 검증 통과: '타겟 페르소나'가 '{task.target_persona}'로 정의되었습니다.\")\n        task.pipeline_stage = 'PLANNING'\n        task.status = 'IN_PROGRESS'\n        print(f\"[{task.id}] >> 다음 단계로 진행: {task.pipeline_stage}, 상태 변경: {task.status}\")\n\n    print(f\"[{task.id}] 검증 완료.\")\n    return task\n\n\nif __name__ == '__main__':\n    # 시뮬레이션: SOC-101 태스크 (타겟 페르소나 필드가 비어있는 경우)\n    print(\"=\"*50)\n    print(\"CASE 1: 타겟 페르소나 필드가 비어있는 경우 (SOC-101)\")\n    print(\"=\"*50)\n    task_soc_101 = Task(task_id='SOC-101', target_persona=None, content=\"새로운 AI 기능 소개 콘텐츠\")\n    print(f\"처리 전: {task_soc_101}\")\n    updated_task_soc_101 = process_to_planning_stage(task_soc_101)\n    print(f\"처리 후: {updated_task_soc_101}\\n\")\n\n    # 시뮬레이션: SOC-102 태스크 (타겟 페르소나 필드가 채워져 있는 경우)\n    print(\"=\"*50)\n    print(\"CASE 2: 타겟 페르소나 필드가 채워져 있는 경우 (SOC-102)\")\n    print(\"=\"*50)\n    task_soc_102 = Task(task_id='SOC-102', target_persona=\"1인 기업 대표 및 프리랜서\", content=\"생산성 향상 팁 콘텐츠\")\n    print(f\"처리 전: {task_soc_102}\")\n    updated_task_soc_102 = process_to_planning_stage(task_soc_102)\n    print(f\"처리 후: {updated_task_soc_102}\")\n```\n\n<next_sprint>\n{\n  \"title\": \"콘텐츠 파이프라인 검증 로직 코드 리뷰 요청\",\n  \"content\": \"대표님 지시에 따라 콘텐츠 파이프라인의 '기획' 단계 진입 전 '타겟 페르소나' 필드를 검증하는 로직을 추가했습니다. `src/pipelines/content_validator.py` 파일에 구현했으며, 필드가 비어있을 경우 태스크 상태를 'NEEDS_DEFINITION'으로 변경합니다. 코드 리뷰 및 시스템 통합 가능 여부 검토 부탁드립니다.\",\n  \"assignee\": \"dev_advisor\"\n}\n</next_sprint>",
