\cb3 \uc0\u48708 \u51592 \u45768 \u49828  \u47589 \u46973  \u44057 \u51008  \u44163 \u46308 \u51012  \u50668 \u44592 \u45796  \u51201 \u50612  \u51469 \u45768 \u45796 . \u44536 \u47100  \u50668 \u44592 \u49436  \u50612 \u46523 \u44172  \u54644 \u50556  \u46104 \u45264 \u47732  \u52968 \u53581 \u49828 \u53944 \u46972 \u44256  \u54616 \u45716  \u54260 \u45908 \u47484  \u54616 \u45208  \u47564 \u46300 \u45716  \u44163 \u51060 \u51424 . \u44536 \u47532 \u44256  \u46608 \cb1 \
