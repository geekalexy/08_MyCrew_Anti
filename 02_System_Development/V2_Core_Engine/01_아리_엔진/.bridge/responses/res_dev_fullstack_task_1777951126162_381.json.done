  "requestedModel": "anti-gemini-3.1-pro-high",
  "text": "### `src/services/rule_engine_optimizer.py`\n\n```python\nimport time\nimport psutil\nfrom functools import wraps\nimport logging\n\n# 로깅 설정\nlogging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')\n\ndef monitor_performance(func):\n    \"\"\"\n    규칙 실행 함수의 성능(실행 시간, CPU 사용률)을 측정하는 데코레이터.\n    정확한 CPU 사용률 측정을 위해 프로세스의 사용자/시스템 CPU 시간을 사용합니다.\n    \"\"\"\n    @wraps(func)\n    def wrapper(self, rule, *args, **kwargs):\n        process = psutil.Process()\n        \n        # CPU 및 시간 측정 시작\n        start_cpu_times = process.cpu_times()\n        start_time = time.perf_counter()\n\n        # 원본 함수(규칙) 실행\n        result = func(self, rule, *args, **kwargs)\n\n        # CPU 및 시간 측정 종료\n        end_time = time.perf_counter()\n        end_cpu_times = process.cpu_times()\n        \n        # 성능 지표 계산\n        elapsed_time_ms = (end_time - start_time) * 1000\n        cpu_time_delta = (end_cpu_times.user - start_cpu_times.user) + \\\n                         (end_cpu_times.system - start_cpu_times.system)\n        \n        # 경과 시간 대비 CPU 시간 비율로 사용률 계산\n        # 참고: 이 값은 단일 코어 사용률을 나타내며 100%를 초과할 수 있음 (멀티코어 활용 시)\n        cpu_usage_percent = (cpu_time_delta / (end_time - start_time)) * 100 if (end_time - start_time) > 0 else 0\n\n        # 측정된 메트릭 저장\n        if not hasattr(self, 'metrics'):\n            self.metrics = {}\n        self.metrics[rule['id']] = {\n            'elapsed_time_ms': elapsed_time_ms,\n            'cpu_usage_percent': cpu_usage_percent\n        }\n        logging.info(f\"Rule '{rule['id']}' executed. Time: {elapsed_time_ms:.2f}ms, CPU: {cpu_usage_percent:.2f}%\")\n        \n        return result\n    return wrapper\n\nclass RuleEngineOptimizer:\n    \"\"\"\n    데코레이터 패턴과 개별 임계값 설정을 적용하여 규칙 엔진을 최적화합니다.\n    \"\"\"\n    def __init__(self, rule_specific_thresholds=None):\n        \"\"\"\n        초기화 메서드.\n        :param rule_specific_thresholds: 룰 ID를 키로, 임계값 딕셔너리를 값으로 갖는 딕셔너리.\n                                         예: {'RULE_001': {'max_execution_time_ms': 50, 'max_cpu_usage_percent': 20}}\n        \"\"\"\n        self.metrics = {}\n        self.rule_specific_thresholds = rule_specific_thresholds if rule_specific_thresholds is not None else {}\n        self.default_thresholds = {\n            'max_execution_time_ms': 100,\n            'max_cpu_usage_percent': 15.0\n        }\n        logging.info(\"RuleEngineOptimizer initialized.\")\n\n    def _get_thresholds_for_rule(self, rule_id):\n        \"\"\"특정 규칙에 대한 임계값을 가져옵니다. 지정되지 않은 경우 기본값을 반환합니다.\"\"\"\n        return self.rule_specific_thresholds.get(rule_id, self.default_thresholds)\n\n    @monitor_performance\n    def _execute_rule(self, rule: dict):\n        \"\"\"\n        단일 규칙을 실행합니다. 실제 실행 로직을 시뮬레이션합니다.\n        @monitor_performance 데코레이터에 의해 성능이 측정됩니다.\n        \"\"\"\n        logging.info(f\"Executing rule logic for: {rule['id']}\")\n        # 시뮬레이션을 위한 CPU 집약적 작업\n        workload = rule.get('workload', 0.05)\n        start = time.perf_counter()\n        while time.perf_counter() - start < workload:\n            _ = [i*i for i in range(1000)] # CPU 부하 생성\n        return {\"status\": \"success\", \"rule_id\": rule['id']}\n\n    def find_inefficient_rules(self, rules: list[dict]) -> list[dict]:\n        \"\"\"\n        규칙 목록을 실행하고 성능 임계값을 초과하는 비효율적인 규칙을 식별합니다.\n        \"\"\"\n        self.metrics.clear()\n        inefficient_rules = []\n\n        for rule in rules:\n            try:\n                self._execute_rule(rule)\n                rule_id = rule['id']\n                \n                if rule_id in self.metrics:\n                    metrics = self.metrics[rule_id]\n                    thresholds = self._get_thresholds_for_rule(rule_id)\n\n                    if metrics['elapsed_time_ms'] > thresholds['max_execution_time_ms']:\n                        inefficiency_info = {\n                            'id': rule_id,\n                            'reason': 'Exceeded max execution time',\n                            'value': f\"{metrics['elapsed_time_ms']:.2f}ms\",\n                            'threshold': f\"{thresholds['max_execution_time_ms']}ms\"\n                        }\n                        inefficient_rules.append(inefficiency_info)\n                        logging.warning(f\"Inefficient rule found: {inefficiency_info}\")\n                    \n                    elif metrics['cpu_usage_percent'] > thresholds['max_cpu_usage_percent']:\n                        inefficiency_info = {\n                            'id': rule_id,\n                            'reason': 'Exceeded max CPU usage',\n                            'value': f\"{metrics['cpu_usage_percent']:.2f}%\",\n                            'threshold': f\"{thresholds['max_cpu_usage_percent']}%\"\n                        }\n                        inefficient_rules.append(inefficiency_info)\n                        logging.warning(f\"Inefficient rule found: {inefficiency_info}\")\n\n            except Exception as e:\n                logging.error(f\"Error executing rule {rule.get('id', 'N/A')}: {e}\")\n        \n        return inefficient_rules\n\n```\n\n---\n\n### `tests/test_rule_engine_optimizer.py`\n\n```python\nimport unittest\nimport sys\nimport os\n\n# 프로젝트 루트를 sys.path에 추가하여 모듈을 임포트할 수 있도록 함\nsys.path.insert(0, os.path.abspath(os.path.join(os.path.dirname(__file__), '..')))\n\nfrom src.services.rule_engine_optimizer import RuleEngineOptimizer\n\nclass TestRuleEngineOptimizer(unittest.TestCase):\n\n    def setUp(self):\n        \"\"\"테스트 실행 전에 호출되는 설정 메서드\"\"\"\n        self.rules = [\n            {'id': 'RULE_001', 'workload': 0.02},  # 정상\n            {'id': 'RULE_002', 'workload': 0.15},  # 시간 초과 (기본 임계값)\n            {'id': 'RULE_003', 'workload': 0.08},  # 시간 초과 (사용자 정의 임계값)\n            {'id': 'RULE_004', 'workload': 0.01},  # 정상 (사용자 정의 임계값)\n        ]\n        \n        self.custom_thresholds = {\n            'RULE_003': {'max_execution_time_ms': 50, 'max_cpu_usage_percent': 20.0},\n            'RULE_004': {'max_execution_time_ms': 200, 'max_cpu_usage_percent': 90.0}\n        }\n        \n        self.optimizer = RuleEngineOptimizer(rule_specific_thresholds=self.custom_thresholds)\n\n    def test_initialization(self):\n        \"\"\"초기화가 정상적으로 이루어지는지 테스트\"\"\"\n        self.assertIsNotNone(self.optimizer)\n        self.assertEqual(self.optimizer.rule_specific_thresholds, self.custom_thresholds)\n        self.assertIn('max_execution_time_ms', self.optimizer.default_thresholds)\n\n    def test_find_inefficient_rules_by_time(self):\n        \"\"\"실행 시간을 기준으로 비효율적인 규칙을 올바르게 식별하는지 테스트\"\"\"\n        inefficient = self.optimizer.find_inefficient_rules(self.rules)\n        \n        inefficient_ids = [r['id'] for r in inefficient]\n        \n        self.assertIn('RULE_002', inefficient_ids, \"RULE_002 should be detected as inefficient by default threshold\")\n        self.assertIn('RULE_003', inefficient_ids, \"RULE_003 should be detected as inefficient by custom threshold\")\n        self.assertNotIn('RULE_001', inefficient_ids, \"RULE_001 should be efficient\")\n        self.assertNotIn('RULE_004', inefficient_ids, \"RULE_004 should be efficient with its custom threshold\")\n\n        # 이유 확인\n        rule_002_result = next((r for r in inefficient if r['id'] == 'RULE_002'), None)\n        self.assertIsNotNone(rule_002_result)\n        self.assertEqual(rule_002_result['reason'], 'Exceeded max execution time')\n        \n    def test_performance_metrics_are_recorded(self):\n        \"\"\"데코레이터가 성능 메트릭을 정상적으로 기록하는지 테스트\"\"\"\n        self.optimizer.find_inefficient_rules([self.rules[0]])\n        \n        self.assertIn('RULE_001', self.optimizer.metrics)\n        rule_metrics = self.optimizer.metrics['RULE_001']\n        self.assertIn('elapsed_time_ms', rule_metrics)\n        self.assertIn('cpu_usage_percent', rule_metrics)\n        self.assertGreater(rule_metrics['elapsed_time_ms'], 0)\n        # CPU 사용률은 환경에 따라 변동이 크므로 0 이상인지만 확인\n        self.assertGreaterEqual(rule_metrics['cpu_usage_percent'], 0)\n\n    def test_get_thresholds_for_rule(self):\n        \"\"\"규칙별 임계값을 올바르게 반환하는지 테스트\"\"\"\n        # 사용자 정의 임계값이 있는 경우\n        custom = self.optimizer._get_thresholds_for_rule('RULE_003')\n        self.assertEqual(custom['max_execution_time_ms'], 50)\n        \n        # 사용자 정의 임계값이 없는 경우 (기본값)\n        default = self.optimizer._get_thresholds_for_rule('RULE_001')\n        self.assertEqual(default['max_execution_time_ms'], self.optimizer.default_thresholds['max_execution_time_ms'])\n\nif __name__ == '__main__':\n    unittest.main()\n```\n<next_sprint>\n{\n  \"title\": \"Rule Engine Optimizer 코드 및 유닛 테스트 QA 요청\",\n  \"content\": \"DEV_ADVISOR의 리뷰를 반영하여 `src/services/rule_engine_optimizer.py` 파일을 업데이트하고, 이에 대한 유닛 테스트 `tests/test_rule_engine_optimizer.py`를 작성 완료했습니다. 데코레이터 패턴 도입, CPU 사용률 측정 로직 개선, 규칙별 임계치 설정 기능이 주요 변경 사항입니다. 코드의 안정성, 성능, 요구사항 충족 여부에 대한 종합적인 QA를 진행해 주시기 바랍니다.\",\n  \"assignee\": \"dev_qa\"\n}\n</next_sprint>",
