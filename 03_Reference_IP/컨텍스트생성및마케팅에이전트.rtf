\cb3 \uc0\u50504 \u54000 \u44536 \u47000 \u54588 \u54000 \u47484  \u50416 \u49492 \u46020  \u50500 \u47924 \u47088  \u47928 \u51228 \u44032  \u50630 \u49845 \u45768 \u45796 . \u45796  \u51064 \u53552 \u54168 \u51060 \u49828 \u45716  \u45824 \u48512 \u48516  \u48708 \u49847 \u54620 \u45936 \u50836 . \u51068 \u45800 \u51008  \u51200 \u45716  \u52964 \u49436 \u47196 \cb1 \
\cb3 \uc0\u51652 \u54665 \u51012  \u54620 \u48264  \u54644  \u48372 \u46020 \u47197  \u54616 \u44192 \u49845 \u45768 \u45796 . \u44536 \u47084 \u47732  \u50668 \u44592 \u49436  \u47924 \u50631 \u51012  \u54616 \u47732  \u51339 \u51012 \u44620 \u50836 ? \u50724 \u54536  \u54532 \u47196 \u51229 \u53944 \u47484  \u51060 \u47111 \u44172  \u45572 \u47493 \u45768 \u45796 . \u44536 \u47084 \u47732 \u51008  \u51648 \u44552  \u51228 \u44032  \u52524 \u50689  \u54260 \u45908 \u46972 \u44256 \cb1 \
\cb3 \uc0\u54616 \u45208  \u47564 \u46308 \u50612  \u45480 \u45716 \u45936 \u50836 . \u50668 \u44592 \u49436  \u49352 \u47213 \u44172  \u54260 \u45908 \u47484  \u54616 \u47732  \u47564 \u46300 \u45716  \u44144 \u51424 . \u44536 \u47000 \u49436  \u44536 \u45285  \u54620 \u44544 \u47196  \u50416 \u49492 \u46020  \u47924 \u48169 \u54616 \u45796 \u44256 \cb1 \
\cb3 \uc0\u49373 \u44033 \u54633 \u45768 \u45796 . \u47560 \u52992 \u54021 , \u50640 \u51060 \u51204 \u53944 , \u54016 \u51060 \u46972 \u44256  \u54644 \u49436  \u47564 \u46308 \u50612  \u48372 \u44256 \u50836 . \u51060 \u47111 \u44172 \u49436  \u47564 \u46308 \u44172  \u46104 \u47732 \u51008  \u52964 \u49436 \u50640  \u51652 \u51077 \u51012 \cb1 \
\cb3 \uc0\u54616 \u44172  \u46104 \u45716 \u45936  \u52964 \u49436  \u51200 \u45716 \u51060  \u48512 \u48516 \u51012  \u45124 \u44256 \u50836 . \u50668 \u44592  \u48372 \u49884 \u47732  \u54869 \u51109  \u46020 \u44396  \u44057 \u51008 \u44172  \u51080 \u49845 \u45768 \u45796 . \u51060 \u51228  \u54869 \u51109  \u46020 \u44396 \u46972 \u44256 \cb1 \
\cb3 \uc0\u54644  \u44032 \u51648 \u44256  \u50668 \u44592 \u49436  \u50668 \u47084 \u48516 \u46308 \u51060  \u53364 \u47196 \u46300  \u53076 \u46300 \u46972 \u44256  \u51060 \u47111 \u44172  \u44160 \u49353 \u51012  \u54616 \u49884 \u47732  \u51060 \u47111 \u44172  \u53364 \u47196 \u46300  \u53076 \u46300  4 vs \u53076 \u46300 \u46972 \u44256  \u54616 \u45716 \cb1 \
\cb3 \uc0\u54869 \u51109  \u46020 \u44396 \u44032  \u46905 \u45768 \u45796 . \u51200  \u44057 \u51008  \u44221 \u50864 \u50640 \u45716  \u51060 \u48120  \u49444 \u52824 \u47484  \u54644  \u45480 \u44592  \u46412 \u47928 \u50640  \u50668 \u44592 \u49436  \u49324 \u50857  \u50504 \u54632 \u51060 \u46972 \u44256  \u50024  \u51080 \u45716 \u45936 \cb1 \
\cb3 \uc0\u50668 \u47084 \u48516 \u46308 \u51008  \u51060 \u44152  \u49444 \u52824 \u54616 \u49884 \u47732  \u46104 \u44256 \u50836 . \u44536 \u47532 \u44256  \u51060 \u44152  \u50612 \u46523 \u44172  \u46608  \u48520 \u47084 \u50732  \u44163 \u51064 \u44032 \u46972 \u44256  \u54616 \u47732 \u51008  \u50668 \u44592  \u48372 \u47732 \u51008 \u51060 \cb1 \
\cb3 \uc0\u53364 \u47196 \u46300  \u53076 \u46300  \u50724 \u54536 \u51060 \u46972 \u44256  \u54616 \u45716  \u47700 \u45684 \u44032  \u51080 \u49845 \u45768 \u45796 . \u50668 \u44592 \u49436  \u51060 \u47111 \u44172  \u50724 \u54536  \u54616 \u44172  \u46104 \u47732 \u51008  \u50668 \u47084 \u48516 \u46308 \u51060 \u51060  \u54260 \u45908 \u50640 \u49436  \u53364 \u47196 \u46300 \cb1 \
\cb3 \uc0\u53076 \u46300  \u54869 \u51109  \u46020 \u44396 \u47484  \u50416 \u49892  \u49688 \u44032  \u51080 \u49845 \u45768 \u45796 . \u51060 \u51204 \u50640  \u51200  \u44057 \u51008  \u44221 \u50864 \u50640 \u45716  \u46608  \u53552 \u48120 \u45328 \u50640 \u49436 \u51060  \u53364 \u47196 \u46300  \u53076 \u46300 \u47484  \u53020 \u44172 \cb1 \
\cb3 \uc0\u46104 \u50632 \u45716 \u45936  \u50724 \u45720 \u51008  \u50668 \u47084 \u48516 \u46308 \u51060  \u51328  \u45908  \u48372 \u44592  \u54200 \u54616 \u49892  \u49688  \u51080 \u46020 \u47197  \u53364 \u47196 \u46300  \u53076 \u46300  \u54869 \u51109  \u54532 \u47196 \u44536 \u47016 \u51004 \u47196  \u54620 \u48264  \u51652 \u51077 \u51012  \u54644 \cb1 \
\cb3 \uc0\u48372 \u45716  \u54805 \u53468 \u45796 \u46972 \u44256  \u48380  \u49688 \u44032  \u51080 \u44192 \u49845 \u45768 \u45796 . \u44536 \u47084 \u47732  \u50668 \u44592 \u49436  \u44536 \u45796 \u51020 \u50640  \u54644 \u50556  \u46112  \u51068 \u51008  \u47952 \u45264 \u47732  \u54260 \u45908 \u47484  \u47564 \u46300 \u45716  \u51068 \u51064 \u45936 \u50836 .\cb1 \
