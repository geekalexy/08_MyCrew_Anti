  "text": "<file_operations>\n[\n  {\n    \"action\": \"write\",\n    \"type\": \"output\",\n    \"path\": \"src/functions/users/me/get.ts\",\n    \"content\": \"import { APIGatewayProxyHandler } from 'aws-lambda';\\nimport { DynamoDBClient } from '@aws-sdk/client-dynamodb';\\nimport { DynamoDBDocumentClient, GetCommand } from '@aws-sdk/lib-dynamodb';\\nimport { getUserIdFromEvent } from '../../../utils/auth'; // Assuming an auth utility exists\\n\\nconst client = new DynamoDBClient({});\\nconst docClient = DynamoDBDocumentClient.from(client);\\n\\n// --- START: Review Feedback #1 반영 ---\\n// 민감 정보를 제외하고 클라이언트에 전달할 사용자 정보만 정의\\ninterface UserProfile {\\n  userId: string;\\n  email: string;\\n  nickname: string;\\n  profilePictureUrl?: string;\\n  createdAt: string;\\n}\\n// --- END: Review Feedback #1 반영 ---\\n\\nexport const handler: APIGatewayProxyHandler = async (event) => {\\n  try {\\n    const userId = getUserIdFromEvent(event); // JWT 토큰에서 사용자 ID 추출\\n    if (!userId) {\\n      return {\\n        statusCode: 401,\\n        body: JSON.stringify({ message: 'Unauthorized' }),\\n      };\\n    }\\n\\n    const command = new GetCommand({\\n      TableName: process.env.USERS_TABLE_NAME,\\n      Key: {\\n        userId,\\n      },\\n    });\\n\\n    const { Item } = await docClient.send(command);\\n\\n    if (!Item) {\\n      return {\\n        statusCode: 404,\\n        body: JSON.stringify({ message: 'User not found' }),\\n      };\\n    }\\n\\n    // --- START: Review Feedback #1 반영 ---\\n    // 데이터베이스에서 조회한 전체 사용자 정보에서 민감 정보를 필터링\\n    const userProfile: UserProfile = {\\n      userId: Item.userId,\\n      email: Item.email,\\n      nickname: Item.nickname,\\n      profilePictureUrl: Item.profilePictureUrl,\\n      createdAt: Item.createdAt,\\n    };\\n    // --- END: Review Feedback #1 반영 ---\\n\\n    return {\\n      statusCode: 200,\\n      body: JSON.stringify(userProfile),\\n    };\\n  } catch (error) {\\n    console.error(error);\\n    return {\\n      statusCode: 500,\\n      body: JSON.stringify({ message: 'Internal Server Error' }),\\n    };\\n  }\\n};\\n\"\n  },\n  {\n    \"action\": \"write\",\n    \"type\": \"output\",\n    \"path\": \"src/functions/users/me/update.ts\",\n    \"content\": \"import { APIGatewayProxyHandler } from 'aws-lambda';\\nimport { DynamoDBClient } from '@aws-sdk/client-dynamodb';\\nimport { DynamoDBDocumentClient, UpdateCommand } from '@aws-sdk/lib-dynamodb';\\nimport { z } from 'zod';\\nimport { getUserIdFromEvent } from '../../../utils/auth';\\n\\nconst client = new DynamoDBClient({});\\nconst docClient = DynamoDBDocumentClient.from(client);\\n\\n// --- START: Review Feedback #2 반영 ---\\n// Zod를 사용하여 요청 Body에 대한 스키마 정의 및 유효성 검사\\nconst UpdateUserSchema = z.object({\\n    nickname: z.string().min(2, 'Nickname must be at least 2 characters long').max(50, 'Nickname must be 50 characters or less').optional(),\\n    profilePictureUrl: z.string().url('Invalid URL format').optional(),\\n}).strict(); // strict()를 사용하여 스키마에 정의되지 않은 필드가 들어오면 에러 발생\\n// --- END: Review Feedback #2 반영 ---\\n\\nexport const handler: APIGatewayProxyHandler = async (event) => {\\n  try {\\n    const userId = getUserIdFromEvent(event);\\n    if (!userId) {\\n      return { statusCode: 401, body: JSON.stringify({ message: 'Unauthorized' }) };\\n    }\\n\\n    if (!event.body) {\\n        return { statusCode: 400, body: JSON.stringify({ message: 'Request body is missing' }) };\\n    }\\n\\n    const rawBody = JSON.parse(event.body);\\n\\n    // --- START: Review Feedback #2 반영 ---\\n    // 입력값 유효성 검사\\n    const validationResult = UpdateUserSchema.safeParse(rawBody);\\n    if (!validationResult.success) {\\n      return {\\n        statusCode: 400,\\n        body: JSON.stringify({\\n          message: 'Invalid input',\\n          errors: validationResult.error.flatten().fieldErrors,\\n        }),\\n      };\\n    }\\n    const validatedBody = validationResult.data;\\n    // --- END: Review Feedback #2 반영 ---\\n    \\n    // --- START: Review Feedback #3 반영 ---\\n    // 요청된 필드만 동적으로 UpdateExpression 생성\\n    const updateExpressionParts: string[] = [];\\n    const expressionAttributeNames: Record<string, string> = {};\\n    const expressionAttributeValues: Record<string, any> = {};\\n\\n    Object.entries(validatedBody).forEach(([key, value]) => {\\n        if (value !== undefined) {\\n            const attrName = `#${key}`;\\n            const attrValue = `:${key}`;\\n            updateExpressionParts.push(`${attrName} = ${attrValue}`);\\n            expressionAttributeNames[attrName] = key;\\n            expressionAttributeValues[attrValue] = value;\\n        }\\n    });\\n\\n    if (updateExpressionParts.length === 0) {\\n        return { statusCode: 400, body: JSON.stringify({ message: 'No fields to update' }) };\\n    }\\n\\n    const updateExpression = `SET ${updateExpressionParts.join(', ')}`;\\n    // --- END: Review Feedback #3 반영 ---\\n\\n    const command = new UpdateCommand({\\n      TableName: process.env.USERS_TABLE_NAME,\\n      Key: { userId },\\n      UpdateExpression: updateExpression,\\n      ExpressionAttributeNames: expressionAttributeNames,\\n      ExpressionAttributeValues: expressionAttributeValues,\\n      ReturnValues: 'ALL_NEW', // 업데이트된 후의 항목을 반환\\n    });\\n\\n    const { Attributes } = await docClient.send(command);\\n\\n    return {\\n      statusCode: 200,\\n      body: JSON.stringify(Attributes),\\n    };\\n  } catch (error) {\\n    console.error(error);\\n    if (error instanceof z.ZodError) { // Zod 에러는 이미 처리되었지만, 만약을 대비한 캐치\\n        return { statusCode: 400, body: JSON.stringify({ message: 'Validation failed', errors: error.errors }) };\\n    }\\n    return {\\n      statusCode: 500,\\n      body: JSON.stringify({ message: 'Internal Server Error' }),\\n    };\\n  }\\n};\\n\"\n  }\n]\n</file_operations>\n<review_request>\n{\n  \"title\": \"사용자 프로필 API 코드 리뷰 피드백 반영\",\n  \"assignee\": \"dev_advisor\",\n  \"message\": \"코드 리뷰에서 지적된 3가지 항목(민감 정보 필터링, 입력값 검증 추가, 동적 UpdateExpression 생성)을 모두 반영했습니다. 코드 재검토 부탁드립니다.\"\n}\n</review_request>",
  "processedBy": "ariDaemon-bridge (gemini-2.5-pro)",
