  "taskId": "task_1777980641030_974",
  "requestedModel": "anti-gemini-3.1-pro-high",
  "text": "<file_operations>\n[\n  {\n    \"action\": \"write\",\n    \"type\": \"output\",\n    \"path\": \"serverless.yml\",\n    \"content\": \"service: user-profile-api\\n\\nframeworkVersion: '3'\\n\\nprovider:\\n  name: aws\\n  runtime: nodejs18.x\\n  region: ap-northeast-2\\n  environment:\\n    USERS_TABLE_NAME: ${self:custom.usersTableName}\\n  iam:\\n    role:\\n      statements:\\n        - Effect: Allow\\n          Action:\\n            - dynamodb:GetItem\\n            - dynamodb:UpdateItem\\n          Resource:\\n            - \\\"Fn::GetAtt\\\": [ UsersTable, Arn ]\\n\\ncustom:\\n  usersTableName: users-table-${sls:stage}\\n\\nfunctions:\\n  # 기존 함수들 (예: auth, etc.) ...\\n\\n  getUserProfile:\\n    handler: src/functions/profile/get.main\\n    events:\\n      - http:\\n          method: get\\n          path: users/me\\n          cors: true\\n          authorizer: \\n            name: jwtAuthorizer # 기존에 정의된 JWT Authorizer 사용을 가정\\n            type: request\\n            identitySource: method.request.header.Authorization\\n\\n  updateUserProfile:\\n    handler: src/functions/profile/update.main\\n    events:\\n      - http:\\n          method: put\\n          path: users/me\\n          cors: true\\n          authorizer:\\n            name: jwtAuthorizer # 기존에 정의된 JWT Authorizer 사용을 가정\\n            type: request\\n            identitySource: method.request.header.Authorization\\n\\nresources:\\n  Resources:\\n    UsersTable:\\n      Type: AWS::DynamoDB::Table\\n      Properties:\\n        TableName: ${self:custom.usersTableName}\\n        AttributeDefinitions:\\n          - AttributeName: userId\\n            AttributeType: S\\n        KeySchema:\\n          - AttributeName: userId\\n            KeyType: HASH\\n        BillingMode: PAY_PER_REQUEST\\n\\n# package, plugins 등 기타 설정은 생략\\n\"\n  },\n  {\n    \"action\": \"write\",\n    \"type\": \"output\",\n    \"path\": \"src/libs/dynamodb-client.ts\",\n    \"content\": \"import { DynamoDBClient } from \\\"@aws-sdk/client-dynamodb\\\";\\nimport { DynamoDBDocumentClient } from \\\"@aws-sdk/lib-dynamodb\\\";\\n\\nconst client = new DynamoDBClient({});\\nconst docClient = DynamoDBDocumentClient.from(client);\\n\\nexport default docClient;\\n\"\n  },\n  {\n    \"action\": \"write\",\n    \"type\": \"output\",\n    \"path\": \"src/libs/api-gateway.ts\",\n    \"content\": \"export const formatJSONResponse = (statusCode: number, response: Record<string, unknown>) => {\\n  return {\\n    statusCode,\\n    headers: {\\n      'Access-Control-Allow-Origin': '*',\\n      'Access-Control-Allow-Credentials': true,\\n    },\\n    body: JSON.stringify(response),\\n  };\\n};\\n\"\n  },\n  {\n    \"action\": \"write\",\n    \"type\": \"output\",\n    \"path\": \"src/functions/profile/get.ts\",\n    \"content\": \"import type { APIGatewayProxyEvent, APIGatewayProxyResult } from \\\"aws-lambda\\\";\\nimport { GetCommand } from \\\"@aws-sdk/lib-dynamodb\\\";\\nimport docClient from \\\"../../libs/dynamodb-client\\\";\\nimport { formatJSONResponse } from \\\"../../libs/api-gateway\\\";\\n\\nconst USERS_TABLE_NAME = process.env.USERS_TABLE_NAME || '';\\n\\nexport const main = async (event: APIGatewayProxyEvent): Promise<APIGatewayProxyResult> => {\\n  // JWT Authorizer를 통해 전달된 사용자 ID 추출\\n  const userId = event.requestContext.authorizer?.principalId;\\n\\n  if (!userId) {\\n    return formatJSONResponse(401, { message: 'Unauthorized' });\\n  }\\n\\n  try {\\n    const command = new GetCommand({\\n      TableName: USERS_TABLE_NAME,\\n      Key: {\\n        userId: userId,\\n      },\\n      ProjectionExpression: 'userId, email, nickname, profilePictureUrl, createdAt' // 비밀번호 등 민감 정보 제외\\n    });\\n\\n    const { Item } = await docClient.send(command);\\n\\n    if (!Item) {\\n      return formatJSONResponse(404, { message: 'User not found' });\\n    }\\n\\n    return formatJSONResponse(200, { user: Item });\\n\\n  } catch (error) {\\n    console.error('Error getting user profile:', error);\\n    return formatJSONResponse(500, { message: 'Internal Server Error' });\\n  }\\n};\\n\"\n  },\n  {\n    \"action\": \"write\",\n    \"type\": \"output\",\n    \"path\": \"src/functions/profile/update.ts\",\n    \"content\": \"import type { APIGatewayProxyEvent, APIGatewayProxyResult } from \\\"aws-lambda\\\";\\nimport { UpdateCommand } from \\\"@aws-sdk/lib-dynamodb\\\";\\nimport docClient from \\\"../../libs/dynamodb-client\\\";\\nimport { formatJSONResponse } from \\\"../../libs/api-gateway\\\";\\n\\nconst USERS_TABLE_NAME = process.env.USERS_TABLE_NAME || '';\\n\\ninterface UpdateProfileBody {\\n    nickname?: string;\\n    profilePictureUrl?: string;\\n}\\n\\nexport const main = async (event: APIGatewayProxyEvent): Promise<APIGatewayProxyResult> => {\\n    const userId = event.requestContext.authorizer?.principalId;\\n\\n    if (!userId) {\\n        return formatJSONResponse(401, { message: 'Unauthorized' });\\n    }\\n\\n    if (!event.body) {\\n        return formatJSONResponse(400, { message: 'Request body is missing' });\\n    }\\n\\n    try {\\n        const data: UpdateProfileBody = JSON.parse(event.body);\\n        const { nickname, profilePictureUrl } = data;\\n\\n        if (!nickname && !profilePictureUrl) {\\n            return formatJSONResponse(400, { message: 'At least one field to update is required: nickname or profilePictureUrl' });\\n        }\\n\\n        let updateExpression = 'set';\\n        const expressionAttributeValues: Record<string, any> = {};\\n        const expressionAttributeNames: Record<string, string> = {};\\n\\n        if (nickname) {\\n            updateExpression += ' #nickname = :nickname,';\\n            expressionAttributeValues[':nickname'] = nickname;\\n            expressionAttributeNames['#nickname'] = 'nickname';\\n        }\\n\\n        if (profilePictureUrl) {\\n            updateExpression += ' #profilePictureUrl = :profilePictureUrl,';\\n            expressionAttributeValues[':profilePictureUrl'] = profilePictureUrl;\\n            expressionAttributeNames['#profilePictureUrl'] = 'profilePictureUrl';\\n        }\\n\\n        // 마지막 쉼표 제거\\n        updateExpression = updateExpression.slice(0, -1);\\n\\n        const command = new UpdateCommand({\\n            TableName: USERS_TABLE_NAME,\\n            Key: { userId },\\n            UpdateExpression: updateExpression,\\n            ExpressionAttributeValues: expressionAttributeValues,\\n            ExpressionAttributeNames: expressionAttributeNames,\\n            ReturnValues: 'ALL_NEW',\\n        });\\n\\n        const { Attributes } = await docClient.send(command);\\n\\n        return formatJSONResponse(200, { user: Attributes });\\n\\n    } catch (error) {\\n        console.error('Error updating user profile:', error);\\n        if (error instanceof SyntaxError) {\\n            return formatJSONResponse(400, { message: 'Invalid JSON format in request body' });\\n        }\\n        return formatJSONResponse(500, { message: 'Internal Server Error' });\\n    }\\n};\\n\"\n  }\n]\n</file_operations>\n<review_request>\n{\n  \"title\": \"사용자 프로필 조회/수정 API 구현 코드 리뷰 요청\",\n  \"assignee\": \"dev_advisor\",\n  \"message\": \"사용자 프로필(GET, PUT /users/me) API 엔드포인트 개발을 완료했습니다. serverless.yml 설정과 Lambda 핸들러 로직(get.ts, update.ts)에 대한 코드 리뷰를 부탁드립니다. 특히 DynamoDB 연동 로직과 IAM 권한 설정이 적절한지 검토해주시면 감사하겠습니다.\"\n}\n</review_request>",
  "processedBy": "ariDaemon-bridge (gemini-2.5-pro)",
