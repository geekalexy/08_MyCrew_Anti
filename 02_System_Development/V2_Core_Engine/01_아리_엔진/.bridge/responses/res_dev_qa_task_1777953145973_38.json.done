  "requestedModel": "anti-claude-sonnet-4.6-thinking",
  "text": "# QA Test Plan: `src/core/context_manager.py`\n\n- **테스트 대상:** `src/core/context_manager.py`\n- **작성자:** DEV_QA\n- **테스트 목적:** 리팩토링된 `ContextManager`의 캐싱, 예외 처리, 싱글톤 패턴, 캐시 무효화 기능의 안정성 및 정확성 검증\n\n---\n\n## 1. 개요\n\n본 문서는 `DEV_ADVISOR`의 리뷰를 바탕으로 수정된 `ContextManager` 모듈의 기능 검증을 위한 테스트 계획을 정의합니다. `pytest` 프레임워크를 사용하여 각 검증 항목에 대한 자동화된 테스트 케이스를 제공합니다.\n\n## 2. 테스트 환경\n\n- **프레임워크:** `pytest`, `pytest-mock`\n- **의존성 설치:**\n  ```bash\n  pip install pytest pytest-mock\n  ```\n- **테스트 실행:** 프로젝트 루트 디렉토리에서 `pytest` 명령어 실행\n\n## 3. 테스트 케이스 상세\n\n### 가정\n아래 테스트 코드는 `src/core/context_manager.py`에 다음과 같은 구조의 `ContextManager` 클래스와 `ContextLoadingError` 예외가 정의되어 있다고 가정합니다.\n\n```python\n# src/core/context_manager.py (예상 구조)\nimport time\nimport os\n\nclass ContextLoadingError(Exception):\n    pass\n\nclass ContextManager:\n    _instance = None\n    # ... (싱글톤 로직) ...\n\n    def __init__(self, ttl=300):\n        if not hasattr(self, 'initialized'):\n            self._cache = {}\n            self.ttl = ttl\n            self.initialized = True\n\n    def get_context(self, file_path: str) -> str:\n        # ... (캐시 확인, 로드, TTL 로직) ...\n        pass\n\n    def invalidate_cache(self, file_path: str = None):\n        # ... (캐시 무효화 로직) ...\n        pass\n```\n\n### `tests/core/test_context_manager.py`\n\n```python\nimport pytest\nimport time\nimport os\nfrom unittest.mock import patch\n\n# 테스트 대상 모듈 import\n# 경로가 올바르지 않다면, sys.path에 프로젝트 루트를 추가해야 할 수 있습니다.\nfrom src.core.context_manager import ContextManager, ContextLoadingError\n\n@pytest.fixture(autouse=True)\ndef clear_singleton():\n    \"\"\"각 테스트 실행 전에 싱글톤 인스턴스를 초기화합니다.\"\"\"\n    ContextManager._instance = None\n    yield\n\n\n@pytest.fixture\ndef manager():\n    \"\"\"테스트에 사용할 ContextManager 인스턴스를 생성합니다.\"\"\"\n    return ContextManager(ttl=10) # 테스트를 위해 TTL을 10초로 설정\n\n\ndef test_singleton_pattern(manager):\n    \"\"\"\n    [검증 항목 3] 싱글톤 패턴 검증:\n    여러 번 인스턴스화해도 동일한 객체와 캐시를 공유하는지 확인합니다.\n    \"\"\"\n    # Arrange\n    cm1 = ContextManager()\n    cm2 = ContextManager()\n\n    # Act & Assert\n    assert cm1 is cm2, \"ContextManager 인스턴스가 동일하지 않습니다 (싱글톤 실패).\"\n\n    # 캐시 공유 확인\n    # Arrange\n    dummy_file_path = \"singleton_test.txt\"\n    with open(dummy_file_path, \"w\") as f:\n        f.write(\"shared cache content\")\n\n    # Act\n    cm1.get_context(dummy_file_path)\n\n    # Assert\n    assert dummy_file_path in cm2._cache, \"하나의 인스턴스에서 로드한 캐시가 다른 인스턴스에 공유되지 않습니다.\"\n\n    # Cleanup\n    os.remove(dummy_file_path)\n\n\ndef test_caching_and_ttl_expiration(manager, tmp_path, mocker):\n    \"\"\"\n    [검증 항목 1] 캐싱 로직 및 TTL 검증:\n    - 최초 로드 시 파일 내용을 반환하고 캐시에 저장하는지 확인합니다.\n    - TTL 만료 전에는 캐시된 내용을 반환하는지 확인합니다.\n    - TTL 만료 후에는 파일에서 새로운 내용을 다시 로드하는지 확인합니다.\n    \"\"\"\n    # Arrange\n    context_file = tmp_path / \"context.txt\"\n    context_file.write_text(\"Initial content\")\n    \n    # time.time() 모킹\n    mock_time = mocker.patch('time.time')\n    \n    # --- 1. 최초 로드 및 캐싱 확인 ---\n    # Act\n    mock_time.return_value = 1000.0\n    content1 = manager.get_context(str(context_file))\n\n    # Assert\n    assert content1 == \"Initial content\"\n    assert str(context_file) in manager._cache\n\n    # --- 2. TTL 만료 전 캐시 사용 확인 ---\n    # Arrange\n    context_file.write_text(\"Updated content\") # 파일 내용 변경\n    \n    # Act\n    mock_time.return_value = 1005.0 # TTL(10초) 이내\n    content2 = manager.get_context(str(context_file))\n\n    # Assert\n    assert content2 == \"Initial content\", \"TTL 만료 전에 캐시가 아닌 파일을 다시 로드했습니다.\"\n\n    # --- 3. TTL 만료 후 캐시 무효화 및 새로고침 확인 ---\n    # Act\n    mock_time.return_value = 1011.0 # TTL(10초) 경과\n    content3 = manager.get_context(str(context_file))\n\n    # Assert\n    assert content3 == \"Updated content\", \"TTL 만료 후에 새로운 내용을 로드하지 못했습니다.\"\n\n\ndef test_context_loading_error_for_nonexistent_file(manager):\n    \"\"\"\n    [검증 항목 2] 예외 처리 검증:\n    존재하지 않는 파일을 로드 시도 시 ContextLoadingError가 발생하는지 확인합니다.\n    \"\"\"\n    # Arrange\n    non_existent_file = \"this/file/does/not/exist.md\"\n\n    # Act & Assert\n    with pytest.raises(ContextLoadingError) as excinfo:\n        manager.get_context(non_existent_file)\n    \n    assert non_existent_file in str(excinfo.value)\n\n\ndef test_cache_invalidation(manager, tmp_path):\n    \"\"\"\n    [검증 항목 4] 캐시 무효화 검증:\n    - 특정 파일의 캐시를 정확히 제거하는지 확인합니다.\n    - 전체 캐시를 모두 제거하는지 확인합니다.\n    \"\"\"\n    # Arrange\n    file1 = tmp_path / \"file1.txt\"\n    file2 = tmp_path / \"file2.txt\"\n    file1.write_text(\"content1\")\n    file2.write_text(\"content2\")\n\n    # 두 파일을 캐시에 로드\n    manager.get_context(str(file1))\n    manager.get_context(str(file2))\n    assert str(file1) in manager._cache\n    assert str(file2) in manager._cache\n\n    # --- 1. 특정 파일 캐시 무효화 ---\n    # Act\n    manager.invalidate_cache(str(file1))\n\n    # Assert\n    assert str(file1) not in manager._cache, \"특정 파일 캐시가 무효화되지 않았습니다.\"\n    assert str(file2) in manager._cache, \"다른 파일의 캐시가 의도치 않게 삭제되었습니다.\"\n\n    # --- 2. 전체 캐시 무효화 ---\n    # Act\n    manager.invalidate_cache() # 인자 없이 호출 시 전체 무효화\n\n    # Assert\n    assert not manager._cache, \"전체 캐시가 무효화되지 않았습니다.\"\n\n```\n\n## 4. 결론\n\n상기 테스트 케이스들은 `ContextManager`의 핵심 기능인 **캐싱(TTL), 예외 처리, 싱글톤 패턴, 캐시 무효화**를 모두 포함하고 있습니다. `pytest`를 통해 위 `test_context_manager.py` 파일을 실행하여 모든 테스트가 통과하는지 확인해 주시기 바랍니다. 테스트 실패 시, 실패한 케이스의 검증 항목을 중심으로 코드를 다시 검토해야 합니다.\n\n<next_sprint>\n{\n  \"title\": \"[Test] `context_manager.py` 리팩토링 검증 테스트 실행\",\n  \"content\": \"DEV_QA가 작성한 `tests/core/test_context_manager.py` 테스트 계획을 실행하고, 모든 테스트 케이스가 통과하는지 확인 후 결과를 보고해 주세요. 실패하는 테스트가 있다면 원인을 분석하고 수정 후 다시 실행해야 합니다.\",\n  \"assignee\": \"dev_fullstack\"\n}\n</next_sprint>",
