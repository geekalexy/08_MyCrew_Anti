  "requestedModel": "anti-gemini-3.1-pro-high",
  "text": "```python\n# src/core/context_manager.py\n\nimport asyncio\nimport json\nimport os\nfrom functools import wraps\nfrom collections import OrderedDict\nimport logging\nimport aiofiles\nfrom typing import Dict, Any\n\n# 로깅 설정\nlogging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')\n\n# --- 개선 사항 4: 재시도 로직 추가 (Decorator) ---\ndef retry_async_io(retries=3, delay=1, backoff=2):\n    \"\"\"\n    비동기 I/O 작업에 대한 재시도 로직을 적용하는 데코레이터.\n    일시적인 파일 시스템 오류에 대한 안정성을 높입니다.\n    \"\"\"\n    def decorator(func):\n        @wraps(func)\n        async def wrapper(*args, **kwargs):\n            _retries, _delay = retries, delay\n            while _retries > 0:\n                try:\n                    return await func(*args, **kwargs)\n                except (IOError, OSError) as e:\n                    _retries -= 1\n                    if _retries == 0:\n                        logging.error(f\"I/O 작업 최종 실패: {func.__name__} after {retries} retries. Error: {e}\")\n                        raise\n                    msg = (\n                        f\"I/O 작업 실패: {func.__name__}. \"\n                        f\"{_delay}초 후 재시도... ({retries - _retries}/{retries}). Error: {e}\"\n                    )\n                    logging.warning(msg)\n                    await asyncio.sleep(_delay)\n                    _delay *= backoff\n        return wrapper\n    return decorator\n\n\nclass AsyncContextManager:\n    \"\"\"\n    ID 기반 잠금, 비동기 I/O, LRU 캐시, 재시도 로직이 적용된 컨텍스트 관리자.\n    \"\"\"\n    _instance = None\n\n    def __new__(cls, *args, **kwargs):\n        if not cls._instance:\n            cls._instance = super(AsyncContextManager, cls).__new__(cls)\n        return cls._instance\n\n    def __init__(self, storage_path: str = \"contexts\", cache_size: int = 128):\n        # 초기화가 여러 번 실행되는 것을 방지\n        if hasattr(self, '_initialized'):\n            return\n            \n        self.storage_path = storage_path\n        if not os.path.exists(self.storage_path):\n            os.makedirs(self.storage_path)\n\n        # --- 개선 사항 3: LRU 캐시 도입 ---\n        self.cache: OrderedDict[str, Dict[str, Any]] = OrderedDict()\n        self.cache_size = cache_size\n        \n        # --- 개선 사항 1: ID 기반 잠금 ---\n        self.locks: Dict[str, asyncio.Lock] = {}\n        self._locks_lock = asyncio.Lock() # locks 딕셔너리 자체의 동시 접근을 막기 위함\n\n        self._initialized = True\n        logging.info(f\"AsyncContextManager 초기화 완료. 저장 경로: {self.storage_path}, 캐시 크기: {self.cache_size}\")\n\n    async def _get_lock(self, context_id: str) -> asyncio.Lock:\n        \"\"\"컨텍스트 ID에 해당하는 Lock 객체를 반환합니다. 없으면 생성합니다.\"\"\"\n        async with self._locks_lock:\n            if context_id not in self.locks:\n                self.locks[context_id] = asyncio.Lock()\n            return self.locks[context_id]\n\n    def _get_context_path(self, context_id: str) -> str:\n        \"\"\"컨텍스트 파일의 전체 경로를 반환합니다.\"\"\"\n        return os.path.join(self.storage_path, f\"{context_id}.json\")\n\n    # --- 개선 사항 2: 비동기 I/O 적용 및 재시도 로직 통합 ---\n    @retry_async_io()\n    async def _read_from_disk(self, path: str) -> Dict[str, Any]:\n        \"\"\"비동기적으로 디스크에서 파일을 읽습니다.\"\"\"\n        async with aiofiles.open(path, mode='r', encoding='utf-8') as f:\n            content = await f.read()\n            return json.loads(content)\n\n    @retry_async_io()\n    async def _write_to_disk(self, path: str, data: Dict[str, Any]):\n        \"\"\"비동기적으로 디스크에 파일을 씁니다.\"\"\"\n        async with aiofiles.open(path, mode='w', encoding='utf-8') as f:\n            await f.write(json.dumps(data, indent=2, ensure_ascii=False))\n\n    async def get_context(self, context_id: str) -> Dict[str, Any]:\n        \"\"\"\n        지정된 ID의 컨텍스트를 가져옵니다.\n        1. 캐시 확인\n        2. 캐시 없으면 디스크에서 비동기 로드 (ID 기반 잠금 사용)\n        3. 로드 후 캐시에 저장\n        \"\"\"\n        # 1. 캐시 확인\n        if context_id in self.cache:\n            self.cache.move_to_end(context_id) # LRU 로직: 사용된 항목을 맨 뒤로 이동\n            logging.info(f\"[Cache HIT] context_id: {context_id}\")\n            return self.cache[context_id]\n\n        logging.info(f\"[Cache MISS] context_id: {context_id}\")\n        \n        # 2. 캐시 없으면 디스크에서 로드 (잠금 사용)\n        lock = await self._get_lock(context_id)\n        async with lock:\n            # lock 획득 후 다른 코루틴이 이미 캐시에 넣었을 수 있으므로 다시 확인\n            if context_id in self.cache:\n                self.cache.move_to_end(context_id)\n                return self.cache[context_id]\n\n            context_path = self._get_context_path(context_id)\n            try:\n                context_data = await self._read_from_disk(context_path)\n            except FileNotFoundError:\n                logging.warning(f\"컨텍스트 파일 없음: {context_path}. 새 컨텍스트 생성.\")\n                context_data = {}\n\n            # 3. 캐시에 저장 및 LRU 정책 적용\n            self.cache[context_id] = context_data\n            self.cache.move_to_end(context_id)\n            if len(self.cache) > self.cache_size:\n                # 가장 오래 사용되지 않은 항목(맨 앞) 제거\n                oldest_key = next(iter(self.cache))\n                del self.cache[oldest_key]\n                logging.info(f\"[Cache EVICT] 오래된 컨텍스트 제거: {oldest_key}\")\n\n            return context_data\n\n    async def save_context(self, context_id: str, data: Dict[str, Any]):\n        \"\"\"\n        컨텍스트를 저장합니다.\n        1. ID 기반 잠금 획득\n        2. 디스크에 비동기 저장\n        3. 캐시 업데이트\n        \"\"\"\n        lock = await self._get_lock(context_id)\n        async with lock:\n            context_path = self._get_context_path(context_id)\n            await self._write_to_disk(context_path, data)\n\n            # 캐시 업데이트 및 LRU 정책 적용\n            self.cache[context_id] = data\n            self.cache.move_to_end(context_id)\n            if len(self.cache) > self.cache_size:\n                oldest_key = next(iter(self.cache))\n                del self.cache[oldest_key]\n                logging.info(f\"[Cache EVICT] 오래된 컨텍스트 제거: {oldest_key}\")\n            \n            logging.info(f\"컨텍스트 저장 완료: {context_id}\")\n\n    async def update_context(self, context_id: str, partial_data: Dict[str, Any]) -> Dict[str, Any]:\n        \"\"\"\n        기존 컨텍스트에 새로운 데이터를 병합하여 업데이트합니다.\n        \"\"\"\n        lock = await self._get_lock(context_id)\n        async with lock:\n            current_context = await self.get_context(context_id)\n            current_context.update(partial_data)\n            await self.save_context(context_id, current_context)\n            return current_context\n\n# --- 사용 예시 ---\nasync def main():\n    manager = AsyncContextManager(storage_path=\"test_contexts\")\n\n    # 동시성 테스트를 위한 태스크 생성\n    async def worker(worker_id, context_id):\n        print(f\"Worker {worker_id}: '{context_id}' 컨텍스트 읽기 시도\")\n        context = await manager.get_context(context_id)\n        print(f\"Worker {worker_id}: '{context_id}' 초기 컨텍스트: {context}\")\n\n        update_data = {\"last_updated_by\": worker_id, \"count\": context.get(\"count\", 0) + 1}\n        await asyncio.sleep(0.1 * worker_id) # 작업 시간 시뮬레이션\n        \n        print(f\"Worker {worker_id}: '{context_id}' 컨텍스트 업데이트 시도\")\n        updated_context = await manager.update_context(context_id, update_data)\n        print(f\"Worker {worker_id}: '{context_id}' 업데이트된 컨텍스트: {updated_context}\")\n\n    # 초기 데이터 설정\n    await manager.save_context(\"user_A\", {\"name\": \"Alex\", \"count\": 0})\n    await manager.save_context(\"user_B\", {\"name\": \"Sonnet\", \"count\": 0})\n\n    tasks = [\n        worker(1, \"user_A\"),\n        worker(2, \"user_A\"),\n        worker(3, \"user_B\"),\n        worker(4, \"user_A\"),\n        worker(5, \"user_B\"),\n    ]\n    await asyncio.gather(*tasks)\n\n    # 최종 결과 확인\n    final_a = await manager.get_context(\"user_A\")\n    final_b = await manager.get_context(\"user_B\")\n    print(\"\\n--- 최종 결과 ---\")\n    print(f\"user_A 최종 count: {final_a.get('count')}\") # 예상: 3\n    print(f\"user_B 최종 count: {final_b.get('count')}\") # 예상: 2\n\nif __name__ == \"__main__\":\n    # 테스트를 위한 임시 디렉토리 정리\n    import shutil\n    if os.path.exists(\"test_contexts\"):\n        shutil.rmtree(\"test_contexts\")\n        \n    asyncio.run(main())\n\n    if os.path.exists(\"test_contexts\"):\n        shutil.rmtree(\"test_contexts\")\n```\n<next_sprint>\n{\n  \"title\": \"리팩토링된 context_manager.py 코드 리뷰 요청\",\n  \"content\": \"분석 보고서 기반으로 `src/core/context_manager.py` 파일의 리팩토링을 완료했습니다. 주요 개선 사항은 ID 기반 잠금, 비동기 I/O, LRU 캐시, 재시도 로직 추가입니다. 코드의 안정성, 성능 및 설계 패턴의 적절성에 대해 리뷰 부탁드립니다.\",\n  \"assignee\": \"dev_advisor\"\n}\n</next_sprint>",
