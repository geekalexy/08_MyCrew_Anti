  "taskId": "task_1777980915568_466",
  "requestedModel": "anti-gemini-3.1-pro-high",
  "text": "<file_operations>\n[\n  {\n    \"action\": \"write\",\n    \"type\": \"output\",\n    \"path\": \"sam-app/src/handlers/userProfile.js\",\n    \"content\": \"const AWS = require('aws-sdk');\\nconst dynamoDb = new AWS.DynamoDB.DocumentClient();\\n\\nconst TABLE_NAME = process.env.TABLE_NAME;\\n\\nconst response = (statusCode, body) => {\\n  return {\\n    statusCode,\\n    headers: {\\n      'Access-Control-Allow-Origin': '*',\\n      'Content-Type': 'application/json',\\n    },\\n    body: JSON.stringify(body),\\n  };\\n};\\n\\nconst getUserId = (event) => {\\n  // The user ID is expected to be in the 'sub' claim of the JWT token,\\n  // passed by the API Gateway JWT Authorizer.\\n  return event.requestContext.authorizer.jwt.claims.sub;\\n}\\n\\nexports.handler = async (event) => {\\n  const httpMethod = event.httpMethod;\\n  let userId;\\n\\n  try {\\n    userId = getUserId(event);\\n    if (!userId) {\\n        return response(401, { error: 'Unauthorized: User ID not found in token.' });\\n    }\\n  } catch (error) {\\n    console.error('Authorization error:', error);\\n    return response(401, { error: 'Unauthorized: Invalid token or claims.' });\\n  }\\n\\n  switch (httpMethod) {\\n    case 'GET':\\n      return getUserProfile(userId);\\n    case 'PUT':\\n      return updateUserProfile(userId, JSON.parse(event.body));\\n    default:\\n      return response(405, { error: `Unsupported method: ${httpMethod}` });\\n  }\\n};\\n\\nconst getUserProfile = async (userId) => {\\n  const params = {\\n    TableName: TABLE_NAME,\\n    Key: {\\n      userId: userId,\\n    },\\n  };\\n\\n  try {\\n    const { Item } = await dynamoDb.get(params).promise();\\n    if (!Item) {\\n      return response(404, { error: 'User not found.' });\\n    }\\n    // Exclude sensitive data if any before returning\\n    delete Item.passwordHash; \\n    return response(200, Item);\\n  } catch (error) {\\n    console.error('DynamoDB Get Error:', error);\\n    return response(500, { error: 'Could not retrieve user profile.' });\\n  }\\n};\\n\\nconst updateUserProfile = async (userId, data) => {\\n    const { nickname, profilePictureUrl } = data;\\n\\n    if (!nickname && !profilePictureUrl) {\\n        return response(400, { error: 'At least one field (nickname, profilePictureUrl) must be provided for update.' });\\n    }\\n\\n    let updateExpression = 'set';\\n    const expressionAttributeValues = {};\\n    const expressionAttributeNames = {};\\n\\n    if (nickname) {\\n        updateExpression += ' #nickname = :nickname,';\\n        expressionAttributeNames['#nickname'] = 'nickname';\\n        expressionAttributeValues[':nickname'] = nickname;\\n    }\\n\\n    if (profilePictureUrl) {\\n        updateExpression += ' #profilePictureUrl = :profilePictureUrl,';\\n        expressionAttributeNames['#profilePictureUrl'] = 'profilePictureUrl';\\n        expressionAttributeValues[':profilePictureUrl'] = profilePictureUrl;\\n    }\\n\\n    // Remove trailing comma\\n    updateExpression = updateExpression.slice(0, -1);\\n\\n    const params = {\\n        TableName: TABLE_NAME,\\n        Key: {\\n            userId: userId,\\n        },\\n        UpdateExpression: updateExpression,\\n        ExpressionAttributeNames: expressionAttributeNames,\\n        ExpressionAttributeValues: expressionAttributeValues,\\n        ReturnValues: 'ALL_NEW',\\n    };\\n\\n    try {\\n        const { Attributes } = await dynamoDb.update(params).promise();\\n        // Exclude sensitive data if any before returning\\n        delete Attributes.passwordHash;\\n        return response(200, Attributes);\\n    } catch (error) {\\n        console.error('DynamoDB Update Error:', error);\\n        return response(500, { error: 'Could not update user profile.' });\\n    }\\n};\"\n  },\n  {\n    \"action\": \"write\",\n    \"type\": \"output\",\n    \"path\": \"sam-app/template.yaml\",\n    \"content\": \"AWSTemplateFormatVersion: '2010-09-09'\\nTransform: AWS::Serverless-2016-10-31\\nDescription: >\\n  MyCrew API for user profile management\\n\\nGlobals:\\n  Function:\\n    Timeout: 10\\n    MemorySize: 256\\n    Runtime: nodejs18.x\\n    Architectures:\\n      - arm64\\n\\nResources:\\n  # The DynamoDB table to store user profiles\\n  UsersTable:\\n    Type: AWS::Serverless::SimpleTable\\n    Properties:\\n      TableName: MyCrewUsers\\n      PrimaryKey:\\n        Name: userId\\n        Type: String\\n      ProvisionedThroughput:\\n        ReadCapacityUnits: 1\\n        WriteCapacityUnits: 1\\n\\n  # API Gateway with a JWT Authorizer (assuming it's defined here or in a shared template)\\n  ApiGateway:\\n    Type: AWS::Serverless::Api\\n    Properties:\\n      StageName: v1\\n      Auth:\\n        Authorizers:\\n          JWTAuthorizer:\\n            JwtConfiguration:\\n              issuer: !Sub 'https://cognito-idp.${AWS::Region}.amazonaws.com/${UserPoolId}' # Example: Using Cognito\\n              audience:\\n                - !Ref UserPoolClientId\\n            IdentitySource: $request.header.Authorization\\n\\n  # Lambda function for handling user profile operations\\n  UserProfileFunction:\\n    Type: AWS::Serverless::Function\\n    Properties:\\n      CodeUri: src/\\n      Handler: handlers/userProfile.handler\\n      Environment:\\n        Variables:\\n          TABLE_NAME: !Ref UsersTable\\n      Policies:\\n        - DynamoDBCrudPolicy:\\n            TableName: !Ref UsersTable\\n      Events:\\n        GetUserProfile:\\n          Type: Api\\n          Properties:\\n            RestApiId: !Ref ApiGateway\\n            Path: /users/me\\n            Method: get\\n            Auth:\\n              Authorizer: JWTAuthorizer\\n        UpdateUserProfile:\\n          Type: Api\\n          Properties:\\n            RestApiId: !Ref ApiGateway\\n            Path: /users/me\\n            Method: put\\n            Auth:\\n              Authorizer: JWTAuthorizer\\n\\nParameters:\\n  UserPoolId:\\n    Type: String\\n    Description: The Cognito User Pool ID for JWT validation.\\n  UserPoolClientId:\\n    Type: String\\n    Description: The Cognito User Pool Client ID for JWT validation.\\n\\nOutputs:\\n  ApiEndpoint:\\n    Description: \\\"API Gateway endpoint URL\\\"\\n    Value: !Sub \\\"https://${ApiGateway}.execute-api.${AWS::Region}.amazonaws.com/v1\\\"\"\n  }\n]\n</file_operations>\n<review_request>\n{\n  \"title\": \"사용자 프로필 API Production 배포 전 최종 코드 리뷰 요청\",\n  \"assignee\": \"dev_advisor\",\n  \"message\": \"Staging 환경 QA를 통과한 사용자 프로필 조회/수정 API의 최종 코드 및 IaC 스크립트입니다. Production 배포 전 병합을 위해 코드 리뷰 부탁드립니다. 특히 IAM 정책, DynamoDB 연동 로직 및 API Gateway Authorizer 설정 부분을 중점적으로 확인해 주시면 감사하겠습니다.\"\n}\n</review_request>",
  "processedBy": "ariDaemon-bridge (gemini-2.5-pro)",
  "timestamp": "2026-05-05T11:35:44.079Z"
}