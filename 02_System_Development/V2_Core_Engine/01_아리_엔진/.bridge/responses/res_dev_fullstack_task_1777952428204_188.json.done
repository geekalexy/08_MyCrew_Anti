  "taskId": "task_1777952428204_188",
  "requestedModel": "anti-gemini-3.1-pro-high",
  "text": "```python\n# src/pipelines/content_validator.py\n\nimport logging\nfrom dataclasses import dataclass, field\nfrom typing import List, Dict, Any\n\n# =================================================================\n# 1. 상수 관리 (Constants Management)\n# - 하드코딩된 문자열을 별도 클래스로 분리하여 유지보수성 및 재사용성 향상\n# =================================================================\nclass ValidationConstants:\n    \"\"\"콘텐츠 검증에 사용되는 상수들을 정의합니다.\"\"\"\n    # 5 Points Check 항목\n    HOOK_CHECK = \"3초 Hook 유무\"\n    CTA_CHECK = \"명확한 CTA\"\n    PLATFORM_FIT_CHECK = \"플랫폼 규격 매칭\"\n    HASHTAG_CHECK = \"해시태그 10개 이상\"\n    TONE_MANNER_CHECK = \"브랜드 톤앤매너\"\n\n    # 상태 (Status)\n    PASSED = \"PASSED\"\n    FAILED = \"FAILED\"\n    NEEDS_DEFINITION = \"NEEDS_DEFINITION\" # 핵심 요소 부재 시 상태\n\n@dataclass\nclass ContentObject:\n    \"\"\"검증 대상이 되는 콘텐츠 데이터 클래스입니다.\"\"\"\n    content_id: str\n    text: str\n    metadata: Dict[str, Any] = field(default_factory=dict)\n    status: str = \"PENDING\"\n\n# =================================================================\n# 2. 로깅 추가 (Logging Implementation)\n# - print() 대신 표준 로깅 모듈을 사용하여 로그 레벨에 따른 출력 제어 및 포맷팅\n# =================================================================\nlogging.basicConfig(\n    level=logging.INFO,\n    format='%(asctime)s - [%(levelname)s] - %(message)s',\n    datefmt='%Y-%m-%d %H:%M:%S'\n)\n\nclass ContentValidator:\n    \"\"\"\n    콘텐츠 발행 전 최종 QA (5 Points Check)를 수행하는 검증기 클래스입니다.\n    DEV_ADVISOR의 피드백을 반영하여 확장성을 고려한 구조로 개선되었습니다.\n    \"\"\"\n    def __init__(self):\n        # =================================================================\n        # 3. 확장성 고려 (Extensibility)\n        # - 검증 규칙을 메소드로 분리하고, 리스트에 등록하여 관리.\n        # - 새로운 검증 규칙 추가 시, 메소드만 추가하고 `self.checks`에 등록하면 됨.\n        # =================================================================\n        self.checks = [\n            self._check_hook,\n            self._check_cta,\n            self._check_platform_fit,\n            self._check_hashtags,\n            self._check_tone_and_manner,\n        ]\n\n    def _check_hook(self, content: ContentObject) -> (bool, str):\n        \"\"\"3초 Hook 유무를 검증합니다.\"\"\"\n        # 실제 구현에서는 NLP 모델이나 키워드 분석 로직이 포함될 수 있음\n        has_hook = content.metadata.get(\"has_hook\", False)\n        if not has_hook:\n            return False, f\"필수 요소 '3초 Hook'이 정의되지 않았습니다.\"\n        return True, f\"'{ValidationConstants.HOOK_CHECK}' 통과\"\n\n    def _check_cta(self, content: ContentObject) -> (bool, str):\n        \"\"\"명확한 CTA 존재 여부를 검증합니다.\"\"\"\n        cta_keywords = [\"저장\", \"댓글\", \"공유\", \"프로필\", \"링크\"]\n        if not any(keyword in content.text for keyword in cta_keywords):\n            return False, f\"'{ValidationConstants.CTA_CHECK}' 실패: CTA 문구가 없습니다.\"\n        return True, f\"'{ValidationConstants.CTA_CHECK}' 통과\"\n\n    def _check_platform_fit(self, content: ContentObject) -> (bool, str):\n        \"\"\"플랫폼 규격 매칭을 검증합니다.\"\"\"\n        platform = content.metadata.get(\"platform\", \"instagram\")\n        text_length = len(content.text)\n\n        if platform == \"instagram_reels\" and text_length > 2200:\n            return False, f\"'{ValidationConstants.PLATFORM_FIT_CHECK}' 실패: 인스타그램 릴스 글자 수 초과 (현재: {text_length})\"\n        # 다른 플랫폼 규칙 추가 가능\n        return True, f\"'{ValidationConstants.PLATFORM_FIT_CHECK}' 통과\"\n\n    def _check_hashtags(self, content: ContentObject) -> (bool, str):\n        \"\"\"해시태그 개수를 검증합니다.\"\"\"\n        hashtags = content.metadata.get(\"hashtags\", [])\n        if len(hashtags) < 10:\n            return False, f\"'{ValidationConstants.HASHTAG_CHECK}' 실패: 해시태그 10개 미만 (현재: {len(hashtags)}개)\"\n        return True, f\"'{ValidationConstants.HASHTAG_CHECK}' 통과\"\n\n    def _check_tone_and_manner(self, content: ContentObject) -> (bool, str):\n        \"\"\"브랜드 톤앤매너 일관성을 검증합니다.\"\"\"\n        # 실제 구현에서는 톤앤매너 분석 모델이 호출될 수 있음\n        is_consistent = content.metadata.get(\"tone_consistent\", True)\n        if not is_consistent:\n            return False, f\"'{ValidationConstants.TONE_MANNER_CHECK}' 실패: 브랜드 톤앤매너와 불일치\"\n        return True, f\"'{ValidationConstants.TONE_MANNER_CHECK}' 통과\"\n\n    def validate(self, content: ContentObject) -> (str, List[str]):\n        \"\"\"\n        주어진 콘텐츠 객체에 대해 모든 검증 규칙을 실행합니다.\n\n        Returns:\n            (최종 검증 상태, 실패 사유 리스트)\n        \"\"\"\n        logging.info(f\"콘텐츠 ID '{content.content_id}'에 대한 검증을 시작합니다.\")\n        failures = []\n\n        # Hook과 같은 핵심 요소 부재 시 즉시 'NEEDS_DEFINITION'으로 처리\n        has_hook, hook_msg = self._check_hook(content)\n        if not has_hook:\n            logging.error(f\"콘텐츠 ID '{content.content_id}': {hook_msg}\")\n            return ValidationConstants.NEEDS_DEFINITION, [hook_msg]\n\n        # 나머지 검증 실행\n        for check_func in self.checks:\n            is_passed, message = check_func(content)\n            if not is_passed:\n                failures.append(message)\n                logging.warning(f\"콘텐츠 ID '{content.content_id}': {message}\")\n            else:\n                logging.info(f\"콘텐츠 ID '{content.content_id}': {message}\")\n\n        if failures:\n            final_status = ValidationConstants.FAILED\n            logging.warning(f\"콘텐츠 ID '{content.content_id}' 최종 검증 상태: {final_status}\")\n        else:\n            final_status = ValidationConstants.PASSED\n            logging.info(f\"콘텐츠 ID '{content.content_id}' 최종 검증 상태: {final_status}. 모든 검증을 통과했습니다.\")\n\n        return final_status, failures\n\n```\n\n```python\n# src/main_orchestrator.py\n\nimport logging\nfrom typing import List\nfrom pipelines.content_validator import ContentValidator, ContentObject, ValidationConstants\n\nclass MainPipelineOrchestrator:\n    \"\"\"\n    메인 콘텐츠 파이프라인을 관리하고 오케스트레이션하는 클래스.\n    ContentValidator를 통합하여 콘텐츠 상태를 관리합니다.\n    \"\"\"\n    def __init__(self):\n        self.validator = ContentValidator()\n        self.content_db = {} # 간단한 인메모리 DB로 콘텐츠 상태 관리 시뮬레이션\n\n    def add_content_to_pipeline(self, content: ContentObject):\n        \"\"\"파이프라인에 새로운 콘텐츠를 추가합니다.\"\"\"\n        logging.info(f\"새 콘텐츠 '{content.content_id}'가 파이프라인에 추가되었습니다. 초기 상태: {content.status}\")\n        self.content_db[content.content_id] = content\n\n    def run_validation_stage(self, content_id: str):\n        \"\"\"특정 콘텐츠에 대한 검증 단계를 실행합니다.\"\"\"\n        content = self.content_db.get(content_id)\n        if not content:\n            logging.error(f\"콘텐츠 ID '{content_id}'를 찾을 수 없습니다.\")\n            return\n\n        logging.info(f\"'{content_id}'의 검증 단계를 시작합니다...\")\n        content.status = \"IN_VALIDATION\"\n        final_status, failures = self.validator.validate(content)\n\n        # =================================================================\n        # 'NEEDS_DEFINITION' 상태 처리 워크플로우 구현\n        # - 검증 결과에 따라 콘텐츠의 상태를 분기 처리합니다.\n        # =================================================================\n        if final_status == ValidationConstants.NEEDS_DEFINITION:\n            content.status = \"NEEDS_DEFINITION\"\n            logging.critical(\n                f\"'{content_id}'의 핵심 요소가 누락되어 '{content.status}' 상태로 변경됩니다. \"\n                f\"기획 단계(NOVA)로 재요청이 필요합니다. 사유: {failures[0]}\"\n            )\n            # 여기에 기획자에게 알림을 보내는 로직 추가 가능 (e.g., create_kanban_card(\"NOVA\", ...))\n\n        elif final_status == ValidationConstants.FAILED:\n            content.status = \"REVISION_REQUESTED\"\n            logging.warning(\n                f\"'{content_id}'가 검증에 실패하여 '{content.status}' 상태로 변경됩니다. \"\n                f\"수정이 필요합니다. 실패 사유: {failures}\"\n            )\n\n        elif final_status == ValidationConstants.PASSED:\n            content.status = \"VALIDATION_PASSED\"\n            logging.info(f\"'{content_id}'가 모든 검증을 통과하여 '{content.status}' 상태로 변경됩니다. 발행 준비 단계로 이동합니다.\")\n\n        else:\n            content.status = \"UNKNOWN_ERROR\"\n            logging.error(f\"'{content_id}' 처리 중 알 수 없는 상태값({final_status})이 반환되었습니다.\")\n\nif __name__ == '__main__':\n    orchestrator = MainPipelineOrchestrator()\n\n    # 시나리오 1: 핵심 요소(Hook) 누락으로 'NEEDS_DEFINITION' 상태가 되는 경우\n    content_needs_def = ContentObject(\n        content_id=\"IG-REELS-001\",\n        text=\"우리 제품 정말 좋아요. 저장하고 친구에게 공유하세요!\",\n        metadata={\n            \"platform\": \"instagram_reels\",\n            \"has_hook\": False, # Hook이 정의되지 않음\n            \"hashtags\": [\"#제품\", \"#신제품\", \"#추천템\", \"#인생템\", \"#테크\", \"#IT\", \"#일상\", \"#소통\", \"#맞팔\", \"#좋아요\"],\n            \"tone_consistent\": True\n        }\n    )\n\n    # 시나리오 2: 일반적인 검증 실패로 'REVISION_REQUESTED' 상태가 되는 경우\n    content_needs_revision = ContentObject(\n        content_id=\"IG-REELS-002\",\n        text=\"이거 모르면 손해! 당신의 시간을 아껴줄 AI 비서 MyCrew. 지금 바로 확인해보세요.\", # CTA 없음\n        metadata={\n            \"platform\": \"instagram_reels\",\n            \"has_hook\": True,\n            \"hashtags\": [\"#AI비서\", \"#업무자동화\", \"#MyCrew\"], # 해시태그 개수 부족\n            \"tone_consistent\": True\n        }\n    )\n\n    # 시나리오 3: 모든 검증을 통과하는 경우\n    content_passed = ContentObject(\n        content_id=\"IG-REELS-003\",\n        text=\"개발자 필독! 더 이상 야근은 그만. MyCrew가 어떻게 당신의 코딩 시간을 50% 줄여주는지 프로필 링크에서 확인하세요.\",\n        metadata={\n            \"platform\": \"instagram_reels\",\n            \"has_hook\": True,\n            \"hashtags\": [\"#개발자\", \"#코딩\", \"#야근금지\", \"#AI\", \"#업무효율\", \"#생산성\", \"#프로그래머\", \"#개발자그램\", \"#칼퇴\", \"#MyCrew\", \"#필수템\"],\n            \"tone_consistent\": True\n        }\n    )\n\n    # 파이프라인 실행\n    print(\"\\n\" + \"=\"*50)\n    orchestrator.add_content_to_pipeline(content_needs_def)\n    orchestrator.run_validation_stage(\"IG-REELS-001\")\n    print(f\"최종 상태: {orchestrator.content_db['IG-REELS-001'].status}\")\n\n    print(\"\\n\" + \"=\"*50)\n    orchestrator.add_content_to_pipeline(content_needs_revision)\n    orchestrator.run_validation_stage(\"IG-REELS-002\")\n    print(f\"최종 상태: {orchestrator.content_db['IG-REELS-002'].status}\")\n\n    print(\"\\n\" + \"=\"*50)\n    orchestrator.add_content_to_pipeline(content_passed)\n    orchestrator.run_validation_stage(\"IG-REELS-003\")\n    print(f\"최종 상태: {orchestrator.content_db['IG-REELS-003'].status}\")\n\n```\n<next_sprint>\n{\n  \"title\": \"[QA] 콘텐츠 검증 파이프라인 통합 테스트 요청\",\n  \"content\": \"DEV_FULLSTACK입니다. DEV_ADVISOR의 피드백을 반영하여 `src/pipelines/content_validator.py`를 리팩토링하고, `src/main_orchestrator.py`에 검증 모듈을 통합하여 'NEEDS_DEFINITION' 상태 처리 로직까지 구현 완료했습니다. \\n\\n수정된 파일들에 대해 아래 항목을 중심으로 테스트 케이스를 작성하고 실행해 주십시오.\\n1. 각 검증 규칙(Hook, CTA, 플랫폼, 해시태그, 톤앤매너)이 독립적으로 정상 동작하는지 확인\\n2. 핵심 요소(Hook) 누락 시, 정확히 'NEEDS_DEFINITION' 상태로 변경되는지 확인\\n3. 복수의 검증 항목 실패 시, 'REVISION_REQUESTED' 상태로 변경되고 모든 실패 사유가 올바르게 로깅되는지 확인\\n4. 모든 검증 통과 시, 'VALIDATION_PASSED' 상태로 변경되는지 확인\\n\\n수정된 파일 경로: `src/pipelines/content_validator.py`, `src/main_orchestrator.py`\",\n  \"assignee\": \"dev_qa\"\n}\n</next_sprint>",
