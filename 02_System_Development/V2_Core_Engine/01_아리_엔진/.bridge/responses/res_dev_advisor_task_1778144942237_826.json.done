  "text": "```typescript\n/**\n * @file selfCorrection.ts\n * @description AI 에이전트의 자체 검증(Self-Correction) 스킬에 대한 방어 로직 구현\n *\n * 1. 최대 재귀 호출 제한 (MAX_RETRIES = 3)\n * 2. 임계값 동적 조정 (실패 시 10% 하향)\n * 3. 최종 실패 처리 및 어드바이저 보고\n */\n\n// --- 타입 및 인터페이스 정의 ---\n\ntype TaskStatus = 'TODO' | 'IN_PROGRESS' | 'COMPLETED' | 'FAILED' | 'REVIEW';\n\ninterface AgentTask {\n  id: string;\n  content: string | null;\n  status: TaskStatus;\n  history: string[];\n}\n\ninterface QualityCheckResult {\n  passed: boolean;\n  score: number;\n}\n\n// --- 모의 함수 (실제 환경에서는 외부 서비스 또는 모듈로 대체) ---\n\n/**\n * 어드바이저에게 태스크 실패를 알리는 모의 함수\n * @param task 실패한 태스크 객체\n * @param reason 실패 사유\n */\nconst notifyAdvisor = (task: AgentTask, reason: string): void => {\n  console.log(`\n🚨 ADVISOR NOTIFICATION 🚨\n--------------------------\nTask ID: ${task.id} has failed.\nStatus: ${task.status}\nReason: ${reason}\nA ticket has been assigned to dev_advisor for review.\n--------------------------\n  `);\n};\n\n/**\n * 콘텐츠 품질을 검증하는 모의 함수\n * 이 예제에서는 score가 threshold 이상일 경우에만 통과합니다.\n * @param content 검증할 콘텐츠\n * @param threshold 통과 기준 점수\n * @returns QualityCheckResult\n */\nconst checkContentQuality = async (content: string, threshold: number): Promise<QualityCheckResult> => {\n  // 실제 시나리오에서는 이 부분에 LLM을 이용한 평가, 특정 키워드 포함 여부,\n  // 글자 수 제한 등의 복잡한 로직이 포함됩니다.\n  // 여기서는 시뮬레이션을 위해 랜덤 점수를 생성하고, 의도적으로 초기 실패를 유도합니다.\n  const score = Math.random() * 100;\n  console.log(`[Quality Check] Content: \"${content.substring(0, 20)}...\" | Score: ${score.toFixed(2)} | Required: >${threshold.toFixed(2)}`);\n  \n  if (score >= threshold) {\n    return { passed: true, score };\n  }\n  return { passed: false, score };\n};\n\n\n/**\n * 콘텐츠를 생성하는 모의 함수\n * @returns 생성된 콘텐츠 문자열\n */\nconst generateContent = async (): Promise<string> => {\n    // 실제로는 LLM API를 호출하는 로직\n    const variants = [\"Initial Draft\", \"Slightly Improved Version\", \"More Creative Angle\", \"Final Polished Copy\"];\n    const content = variants[Math.floor(Math.random() * variants.length)] + ` (rnd: ${Math.random()})`;\n    console.log(`[Content Generation] New content generated: \"${content}\"`);\n    return content;\n}\n\n\n// --- 핵심 로직 구현 ---\n\nclass SelfCorrectionProcessor {\n  private static readonly MAX_RETRIES = 3;\n  private static readonly THRESHOLD_ADJUSTMENT_RATE = 0.9; // 10% 하향 조정\n\n  public async process(task: AgentTask, initialThreshold: number): Promise<AgentTask> {\n    task.status = 'IN_PROGRESS';\n    task.history.push(`[${new Date().toISOString()}] Processing started with threshold ${initialThreshold}.`);\n    console.log(`--- Starting Self-Correction Process for Task ${task.id} ---`);\n\n    let currentThreshold = initialThreshold;\n\n    // 1. 최대 재시도 (MAX_RETRIES)\n    for (let i = 0; i < SelfCorrectionProcessor.MAX_RETRIES; i++) {\n      task.history.push(`[Attempt ${i + 1}/${SelfCorrectionProcessor.MAX_RETRIES}] Generating content.`);\n      const newContent = await generateContent();\n      const result = await checkContentQuality(newContent, currentThreshold);\n\n      if (result.passed) {\n        task.content = newContent;\n        task.status = 'COMPLETED';\n        task.history.push(`[Attempt ${i + 1}] Quality check passed with score ${result.score.toFixed(2)}.`);\n        console.log(`✅ Success on attempt ${i + 1}! Task ${task.id} is complete.`);\n        console.log(`--- Process Finished for Task ${task.id} ---`);\n        return task;\n      } else {\n        task.history.push(`[Attempt ${i + 1}] Quality check failed with score ${result.score.toFixed(2)}.`);\n      }\n    }\n\n    // 2. 임계값 동적 조정\n    console.log(`[Dynamic Adjustment] All ${SelfCorrectionProcessor.MAX_RETRIES} attempts failed. Adjusting threshold.`);\n    currentThreshold = initialThreshold * SelfCorrectionProcessor.THRESHOLD_ADJUSTMENT_RATE;\n    task.history.push(`[Adjustment] Threshold lowered to ${currentThreshold.toFixed(2)}.`);\n    \n    const finalContent = await generateContent();\n    const finalResult = await checkContentQuality(finalContent, currentThreshold);\n\n    if (finalResult.passed) {\n        task.content = finalContent;\n        task.status = 'COMPLETED';\n        task.history.push(`[Final Attempt] Quality check passed with adjusted threshold. Score: ${finalResult.score.toFixed(2)}.`);\n        console.log(`✅ Success with adjusted threshold! Task ${task.id} is complete.`);\n        console.log(`--- Process Finished for Task ${task.id} ---`);\n        return task;\n    }\n\n    // 3. 최종 실패 처리 및 보고\n    task.status = 'FAILED';\n    const failureReason = `All ${SelfCorrectionProcessor.MAX_RETRIES} attempts and one final attempt with adjusted threshold failed. Last score: ${finalResult.score.toFixed(2)}`;\n    task.history.push(`[Failure] ${failureReason}`);\n    console.error(`❌ Final Failure! Task ${task.id} could not meet the quality standards.`);\n    notifyAdvisor(task, failureReason);\n    console.log(`--- Process Finished for Task ${task.id} ---`);\n\n    return task;\n  }\n}\n\n// --- 실행 예제 ---\n\nconst main = async () => {\n  const initialTask: AgentTask = {\n    id: 'SOC-117-RECOVERY',\n    content: null,\n    status: 'TODO',\n    history: [],\n  };\n\n  const processor = new SelfCorrectionProcessor();\n  // 품질 기준을 의도적으로 높게 설정하여 실패 시나리오 유도 (95점)\n  const finalTaskState = await processor.process(initialTask, 95.0);\n\n  console.log(\"\\n--- FINAL TASK STATE ---\");\n  console.log(JSON.stringify(finalTaskState, null, 2));\n};\n\nmain();\n\n```\n<file_operations>\n[\n  {\n    \"action\": \"write\",\n    \"type\": \"output\",\n    \"path\": \"selfCorrection.ts\",\n    \"content\": \"/**\\n * @file selfCorrection.ts\\n * @description AI 에이전트의 자체 검증(Self-Correction) 스킬에 대한 방어 로직 구현\\n *\\n * 1. 최대 재귀 호출 제한 (MAX_RETRIES = 3)\\n * 2. 임계값 동적 조정 (실패 시 10% 하향)\\n * 3. 최종 실패 처리 및 어드바이저 보고\\n */\\n\\n// --- 타입 및 인터페이스 정의 ---\\n\\ntype TaskStatus = 'TODO' | 'IN_PROGRESS' | 'COMPLETED' | 'FAILED' | 'REVIEW';\\n\\ninterface AgentTask {\\n  id: string;\\n  content: string | null;\\n  status: TaskStatus;\\n  history: string[];\\n}\\n\\ninterface QualityCheckResult {\\n  passed: boolean;\\n  score: number;\\n}\\n\\n// --- 모의 함수 (실제 환경에서는 외부 서비스 또는 모듈로 대체) ---\\n\\n/**\\n * 어드바이저에게 태스크 실패를 알리는 모의 함수\\n * @param task 실패한 태스크 객체\\n * @param reason 실패 사유\\n */\\nconst notifyAdvisor = (task: AgentTask, reason: string): void => {\\n  console.log(`\\n🚨 ADVISOR NOTIFICATION 🚨\\n--------------------------\\nTask ID: ${task.id} has failed.\\nStatus: ${task.status}\\nReason: ${reason}\\nA ticket has been assigned to dev_advisor for review.\\n--------------------------\\n  `);\\n};\\n\\n/**\\n * 콘텐츠 품질을 검증하는 모의 함수\\n * 이 예제에서는 score가 threshold 이상일 경우에만 통과합니다.\\n * @param content 검증할 콘텐츠\\n * @param threshold 통과 기준 점수\\n * @returns QualityCheckResult\\n */\\nconst checkContentQuality = async (content: string, threshold: number): Promise<QualityCheckResult> => {\\n  // 실제 시나리오에서는 이 부분에 LLM을 이용한 평가, 특정 키워드 포함 여부,\\n  // 글자 수 제한 등의 복잡한 로직이 포함됩니다.\\n  // 여기서는 시뮬레이션을 위해 랜덤 점수를 생성하고, 의도적으로 초기 실패를 유도합니다.\\n  const score = Math.random() * 100;\\n  console.log(`[Quality Check] Content: \\\"${content.substring(0, 20)}...\\\" | Score: ${score.toFixed(2)} | Required: >${threshold.toFixed(2)}`);\\n  \\n  if (score >= threshold) {\\n    return { passed: true, score };\\n  }\\n  return { passed: false, score };\\n};\\n\\n\\n/**\\n * 콘텐츠를 생성하는 모의 함수\\n * @returns 생성된 콘텐츠 문자열\\n */\\nconst generateContent = async (): Promise<string> => {\\n    // 실제로는 LLM API를 호출하는 로직\\n    const variants = [\\\"Initial Draft\\\", \\\"Slightly Improved Version\\\", \\\"More Creative Angle\\\", \\\"Final Polished Copy\\\"];\\n    const content = variants[Math.floor(Math.random() * variants.length)] + ` (rnd: ${Math.random()})`;\\n    console.log(`[Content Generation] New content generated: \\\"${content}\\\"`);\\n    return content;\\n}\\n\\n\\n// --- 핵심 로직 구현 ---\\n\\nclass SelfCorrectionProcessor {\\n  private static readonly MAX_RETRIES = 3;\\n  private static readonly THRESHOLD_ADJUSTMENT_RATE = 0.9; // 10% 하향 조정\\n\\n  public async process(task: AgentTask, initialThreshold: number): Promise<AgentTask> {\\n    task.status = 'IN_PROGRESS';\\n    task.history.push(`[${new Date().toISOString()}] Processing started with threshold ${initialThreshold}.`);\\n    console.log(`--- Starting Self-Correction Process for Task ${task.id} ---`);\\n\\n    let currentThreshold = initialThreshold;\\n\\n    // 1. 최대 재시도 (MAX_RETRIES)\\n    for (let i = 0; i < SelfCorrectionProcessor.MAX_RETRIES; i++) {\\n      task.history.push(`[Attempt ${i + 1}/${SelfCorrectionProcessor.MAX_RETRIES}] Generating content.`);\\n      const newContent = await generateContent();\\n      const result = await checkContentQuality(newContent, currentThreshold);\\n\\n      if (result.passed) {\\n        task.content = newContent;\\n        task.status = 'COMPLETED';\\n        task.history.push(`[Attempt ${i + 1}] Quality check passed with score ${result.score.toFixed(2)}.`);\\n        console.log(`✅ Success on attempt ${i + 1}! Task ${task.id} is complete.`);\\n        console.log(`--- Process Finished for Task ${task.id} ---`);\\n        return task;\\n      } else {\\n        task.history.push(`[Attempt ${i + 1}] Quality check failed with score ${result.score.toFixed(2)}.`);\\n      }\\n    }\\n\\n    // 2. 임계값 동적 조정\\n    console.log(`[Dynamic Adjustment] All ${SelfCorrectionProcessor.MAX_RETRIES} attempts failed. Adjusting threshold.`);\\n    currentThreshold = initialThreshold * SelfCorrectionProcessor.THRESHOLD_ADJUSTMENT_RATE;\\n    task.history.push(`[Adjustment] Threshold lowered to ${currentThreshold.toFixed(2)}.`);\\n    \\n    const finalContent = await generateContent();\\n    const finalResult = await checkContentQuality(finalContent, currentThreshold);\\n\\n    if (finalResult.passed) {\\n        task.content = finalContent;\\n        task.status = 'COMPLETED';\\n        task.history.push(`[Final Attempt] Quality check passed with adjusted threshold. Score: ${finalResult.score.toFixed(2)}.`);\\n        console.log(`✅ Success with adjusted threshold! Task ${task.id} is complete.`);\\n        console.log(`--- Process Finished for Task ${task.id} ---`);\\n        return task;\\n    }\\n\\n    // 3. 최종 실패 처리 및 보고\\n    task.status = 'FAILED';\\n    const failureReason = `All ${SelfCorrectionProcessor.MAX_RETRIES} attempts and one final attempt with adjusted threshold failed. Last score: ${finalResult.score.toFixed(2)}`;\\n    task.history.push(`[Failure] ${failureReason}`);\\n    console.error(`❌ Final Failure! Task ${task.id} could not meet the quality standards.`);\\n    notifyAdvisor(task, failureReason);\\n    console.log(`--- Process Finished for Task ${task.id} ---`);\\n\\n    return task;\\n  }\\n}\\n\\n// --- 실행 예제 ---\\n\\nconst main = async () => {\\n  const initialTask: AgentTask = {\\n    id: 'SOC-117-RECOVERY',\\n    content: null,\\n    status: 'TODO',\\n    history: [],\\n  };\\n\\n  const processor = new SelfCorrectionProcessor();\\n  // 품질 기준을 의도적으로 높게 설정하여 실패 시나리오 유도 (95점)\\n  const finalTaskState = await processor.process(initialTask, 95.0);\\n\\n  console.log(\\\"\\\\n--- FINAL TASK STATE ---\\\");\\n  console.log(JSON.stringify(finalTaskState, null, 2));\\n};\\n\\nmain();\\n\"\n  }\n]\n</file_operations>\n<review_request>\n{\n  \"title\": \"[리뷰] AI 에이전트 자체 검증 스킬 방어 로직 구현\",\n  \"assignee\": \"dev_advisor\",\n  \"message\": \"mkt_planner 에이전트의 무한 루프 STUCK 문제를 해결하기 위해 모든 에이전트에 적용될 자체 검증 방어 로직을 구현했습니다.\\n\\n주요 구현 사항:\\n1.  **최대 3회 재시도**: `MAX_RETRIES` 상수를 통해 재시도 횟수를 제한합니다.\\n2.  **임계값 동적 조정**: 3회 실패 시, 품질 기준점을 10% 하향하여 마지막 시도를 수행합니다.\\n3.  **최종 실패 처리**: 모든 시도가 실패할 경우, 태스크 상태를 `FAILED`로 변경하고 `notifyAdvisor` 함수를 호출하여 즉시 보고합니다.\\n\\n`selfCorrection.ts` 파일에 핵심 로직(`SelfCorrectionProcessor` 클래스)과 실행 예제를 포함하여 작성했습니다. 코드 리뷰 부탁드립니다.\"\n}\n</review_request>",
