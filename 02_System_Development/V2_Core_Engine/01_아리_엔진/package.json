{
  "name": "mycrew-bridge-server",
  "version": "1.5.0",
  "description": "Local relay server bridging Antigravity Cloud and Paperclip Local Engine",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "prestart": "lsof -ti:4010 | xargs kill -9 || true",
    "start": "node server.js",
    "predev": "lsof -ti:4010 | xargs kill -9 || true",
    "dev": "node --watch server.js",
    "start:legacy": "PORT=4000 node server.js",
    "dev:legacy": "PORT=4000 node --watch server.js",
    "prestart:mcp-backend": "lsof -ti:4010 | xargs kill -9 || true",
    "start:mcp-backend": "PORT=4010 node server.js",
    "dev:mcp-backend": "PORT=4010 node --watch server.js",
    "presm": "lsof -ti:4010 | xargs kill -9 || true",
    "sm": "PORT=4010 node server.js",
    "start:mcp": "node mcp_server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/genai": "^1.49.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^171.4.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "node-telegram-bot-api": "^0.67.0",
    "open": "^11.0.0",
    "puppeteer-core": "^24.42.0",
    "socket.io": "^4.8.3",
    "sqlite3": "^6.0.1",
    "youtube-transcript": "^1.3.0",
    "yt-search": "^2.11.0",
    "zod": "^4.4.3"
  }
}
