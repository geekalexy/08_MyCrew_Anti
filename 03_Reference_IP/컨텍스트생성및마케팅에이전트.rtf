\cb3 \uc0\u50732 \u46972 \u44032 \u44256  \u51080 \u49845 \u45768 \u45796 . \u46608  \u45433 \u54868 \u47484  \u54616 \u44256  \u51080 \u45716  \u50724 \u45720  \u49884 \u51216 \u50644  \u53364 \u47196 \u46300  \u48120 \u53664 \u49828 \u46972 \u44256  \u54616 \u45716  \u47784 \u45944 \u51060  \u52636 \u49884 \u44032  \u46096 \u45716 \u45936 \u50836 . \u51648 \u44552 \cb1 \
\cb3 \uc0\u44361 \u51109 \u55176  \u49548 \u49688 \u50640 \u44172 \u47564  \u50676 \u47140  \u51080 \u44256  \u51648 \u44552  \u50724 \u54532 \u49828 \u51032  \u49457 \u45733  \u45824 \u48708  \u50628 \u52397 \u45208 \u44172  \u50732 \u46972 \u44052 \u45796 \u44256  \u54633 \u45768 \u45796 . \u44536 \u47000 \u49436  \u50724 \u45720  \u51228 \u44032 \cb1 \
\cb3 \uc0\u48372 \u50668  \u46300 \u47540  \u45236 \u50857 \u51008 \u50836 . \u54260 \u45908 \u47484  \u47564 \u46308 \u44256  \u47589 \u46973 \u51012  \u51452 \u51077 \u54620  \u45796 \u51020 \u50640  \u49828 \u53420 \u44284  \u49436 \u48652  \u50640 \u51060 \u51204 \u53944 \u46308 \u51012  \u45796  \u44396 \u49457 \u51012  \u54616 \u45716  \u54620 \u45348 \u49828 \cb1 \
\cb3 \uc0\u49464 \u54021 \u51032  \u49884 \u44036 \u51012  \u47566 \u51060  \u47566 \u51060  \u46308 \u50668  \u48380  \u44228 \u54925 \u51077 \u45768 \u45796 . \u49324 \u49892  \u49892 \u54665  \u47732 \u50640 \u49436 \u45716  \u53364 \u47196 \u46300 \u44032  \u53252 \u47532 \u54000 \u44032  \u45208 \u50724 \u44172  \u54616 \u44592 \cb1 \
\cb3 \uc0\u50948 \u54644 \u49436 \u45716  \u54620 \u45348 \u49828  \u49464 \u54021 \u50640  95%\u51032  \u49884 \u44036 \u51012  \u50024 \u50556  \u46108 \u45796 \u46972 \u44256  \u49373 \u44033 \u51012  \u54616 \u44172  \u46104 \u50632 \u50612 \u50836 . 5%\u45716  \u49892 \u54665  \u49884 \u44036 \u50640  \u50416 \u45716 \cb1 \
\cb3 \uc0\u44163 \u51060 \u51424 . \u44536 \u47084 \u47732 \u49436  \u50612  \u51228 \u44032 \u51060  \u47784 \u46304  \u44284 \u51221 \u46308 \u51012  \u50629 \u45936 \u51060 \u53944 \u54616 \u44256  \u50612 \u46523 \u44172  \u47564 \u46308 \u50612  \u45208 \u44032 \u45716 \u51648  \u46608 \u54620  \u50612 \u46523 \u44172  \u54616 \u47732 \u51008  \u44256 \u54408 \u51656 \u51032 \cb1 \
