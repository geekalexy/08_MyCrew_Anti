  "requestedModel": "anti-gemini-3.1-pro-high",
  "text": "```python\n# src/core/context_manager.py\n\nimport asyncio\nimport json\nfrom pathlib import Path\nfrom typing import Dict, Any, Optional\n\nimport aiofiles\nfrom async_lru import alru_cache\nfrom pydantic import BaseModel, ValidationError, Field\n\n# ==============================================================================\n# 1. 설정 값 외부 분리 (config.py 또는 환경 변수에서 로드)\n# - DEV_ADVISOR 피드백: 하드코딩된 경로와 캐시 설정을 분리하여 유연성 확보\n# ==============================================================================\nclass ContextSettings(BaseModel):\n    \"\"\"Context Manager 설정을 위한 Pydantic 모델\"\"\"\n    context_dir: Path = Path(\"contexts\")\n    cache_max_size: int = 128\n    cache_ttl: int = 300  # 5분\n\n# 실제 애플리케이션에서는 별도 config 파일에서 로드\nsettings = ContextSettings()\n\n\n# ==============================================================================\n# 2. Pydantic을 이용한 데이터 유효성 검사\n# - DEV_ADVISOR 피드백: 딕셔너리 대신 Pydantic 모델을 사용하여 데이터 무결성 강화\n# ==============================================================================\nclass ContextData(BaseModel):\n    \"\"\"컨텍스트 파일의 데이터 구조 정의 및 유효성 검사\"\"\"\n    session_id: str\n    user_id: str\n    history: list[dict[str, Any]] = Field(default_factory=list)\n    metadata: dict[str, Any] = Field(default_factory=dict)\n\n\nclass ContextManager:\n    \"\"\"\n    비동기 컨텍스트 관리자.\n    - 파일 기반 컨텍스트 저장 및 로드\n    - 비동기 잠금을 통한 동시성 제어\n    - LRU 캐시를 통한 성능 최적화\n    - Pydantic을 통한 데이터 유효성 검사\n    \"\"\"\n    _instance = None\n    _locks: Dict[str, asyncio.Lock] = {}\n\n    def __new__(cls, *args, **kwargs):\n        if cls._instance is None:\n            cls._instance = super().__new__(cls)\n        return cls._instance\n\n    def __init__(self, base_path: Path = settings.context_dir):\n        self.base_path = base_path\n        self.base_path.mkdir(parents=True, exist_ok=True)\n\n    def _get_lock(self, context_id: str) -> asyncio.Lock:\n        \"\"\"컨텍스트 ID에 대한 잠금 객체를 가져오거나 생성합니다.\"\"\"\n        if context_id not in self._locks:\n            self._locks[context_id] = asyncio.Lock()\n        return self._locks[context_id]\n\n    # ==============================================================================\n    # 3. async-lru 캐시 도입\n    # - DEV_ADVISOR 피드백: 반복적인 파일 I/O를 줄여 응답 속도 개선\n    # ==============================================================================\n    @alru_cache(maxsize=settings.cache_max_size, ttl=settings.cache_ttl)\n    async def _load_context_from_file(self, context_id: str) -> Optional[ContextData]:\n        \"\"\"\n        파일에서 컨텍스트를 비동기적으로 로드하고 Pydantic 모델로 파싱합니다.\n        캐시가 적용되어 반복적인 디스크 읽기를 최소화합니다.\n        \"\"\"\n        file_path = self.base_path / f\"{context_id}.json\"\n        if not file_path.exists():\n            return None\n        \n        try:\n            async with aiofiles.open(file_path, mode='r', encoding='utf-8') as f:\n                content = await f.read()\n                return ContextData.model_validate_json(content)\n        except (json.JSONDecodeError, ValidationError) as e:\n            # 데이터 파싱 또는 유효성 검사 실패 시 로그 남기고 None 반환\n            print(f\"Error loading or validating context {context_id}: {e}\")\n            return None\n        except IOError as e:\n            print(f\"Error reading context file {context_id}: {e}\")\n            return None\n\n    async def get_context(self, context_id: str) -> Optional[ContextData]:\n        \"\"\"\n        지정된 컨텍스트 ID에 대한 데이터를 안전하게 가져옵니다.\n        캐시를 우선 확인하고, 없으면 파일에서 로드합니다.\n        \"\"\"\n        # ==============================================================================\n        # 4. async with를 사용한 잠금 관리 개선\n        # - DEV_ADVISOR 피드백: lock.acquire/release를 async with로 변경하여 예외 안전성 확보\n        # ==============================================================================\n        lock = self._get_lock(context_id)\n        async with lock:\n            return await self._load_context_from_file(context_id)\n\n    async def update_context(self, context_id: str, data: ContextData) -> bool:\n        \"\"\"\n        컨텍스트 데이터를 파일에 비동기적으로 저장하고 캐시를 무효화합니다.\n        \"\"\"\n        if not isinstance(data, ContextData):\n            raise TypeError(\"Data must be an instance of ContextData model.\")\n\n        lock = self._get_lock(context_id)\n        file_path = self.base_path / f\"{context_id}.json\"\n        \n        async with lock:\n            try:\n                # Pydantic 모델을 JSON 문자열로 변환\n                json_content = data.model_dump_json(indent=2)\n                \n                async with aiofiles.open(file_path, mode='w', encoding='utf-8') as f:\n                    await f.write(json_content)\n                \n                # 캐시 무효화: 기존 캐시를 지우고 새로운 데이터로 채움\n                # 방법 1: 직접 캐시 지우기 (더 명시적)\n                try:\n                    self._load_context_from_file.cache_clear()\n                except Exception as e:\n                     # 캐시가 아직 생성되지 않은 경우 예외 발생 가능\n                     pass\n                \n                # 방법 2: 캐시를 새로운 값으로 업데이트 (alru_cache가 자동으로 처리)\n                # 다음 get_context 호출 시 _load_context_from_file이 실행되어 캐시가 갱신됨.\n                # 여기서는 명시적 무효화를 선택.\n\n                # 업데이트된 내용을 즉시 캐시에 반영\n                await self._load_context_from_file.cache_invalidate(context_id)\n                cache_key = self._load_context_from_file.cache_info().currsize\n                self._load_context_from_file.cache.set(cache_key, data)\n\n\n                return True\n            except IOError as e:\n                print(f\"Error writing context file {context_id}: {e}\")\n                return False\n            except Exception as e:\n                print(f\"An unexpected error occurred during context update: {e}\")\n                return False\n\n    async def create_context(self, context_id: str, user_id: str) -> ContextData:\n        \"\"\"새로운 컨텍스트를 생성하고 저장합니다.\"\"\"\n        new_context = ContextData(session_id=context_id, user_id=user_id)\n        await self.update_context(context_id, new_context)\n        return new_context\n\n# 싱글톤 인스턴스\ncontext_manager = ContextManager()\n\nasync def main():\n    \"\"\"테스트 및 사용 예제\"\"\"\n    test_context_id = \"session_12345\"\n    test_user_id = \"user_abc\"\n\n    # 1. 컨텍스트 생성\n    print(\"1. Creating new context...\")\n    context = await context_manager.create_context(test_context_id, test_user_id)\n    print(f\"   Created: {context}\")\n\n    # 2. 컨텍스트 조회 (파일 I/O 발생 및 캐시 저장)\n    print(\"\\n2. Getting context (first time, loads from file)...\")\n    context = await context_manager.get_context(test_context_id)\n    print(f\"   Retrieved: {context}\")\n    print(f\"   Cache info: {context_manager._load_context_from_file.cache_info()}\")\n\n    # 3. 컨텍스트 조회 (캐시에서 바로 로드)\n    print(\"\\n3. Getting context (second time, from cache)...\")\n    context = await context_manager.get_context(test_context_id)\n    print(f\"   Retrieved from cache: {context}\")\n    print(f\"   Cache info: {context_manager._load_context_from_file.cache_info()}\")\n\n    # 4. 컨텍스트 업데이트\n    if context:\n        print(\"\\n4. Updating context...\")\n        context.history.append({\"role\": \"user\", \"content\": \"Hello, world!\"})\n        context.metadata[\"last_updated\"] = \"2026-05-10T10:00:00Z\"\n        update_success = await context_manager.update_context(test_context_id, context)\n        print(f\"   Update successful: {update_success}\")\n\n    # 5. 업데이트된 컨텍스트 조회 (캐시가 무효화되고 다시 파일에서 로드)\n    print(\"\\n5. Getting updated context (cache was invalidated, re-loads from file)...\")\n    updated_context = await context_manager.get_context(test_context_id)\n    print(f\"   Retrieved updated context: {updated_context}\")\n    print(f\"   Cache info: {context_manager._load_context_from_file.cache_info()}\")\n\n\nif __name__ == \"__main__\":\n    asyncio.run(main())\n```\n<next_sprint>\n{\n  \"title\": \"[QA] Context Manager 개선 사항 기능 검증\",\n  \"content\": \"DEV_ADVISOR의 코드 리뷰 피드백을 반영하여 `src/core/context_manager.py` 파일을 수정했습니다. 주요 변경 사항은 비동기 잠금, LRU 캐시, Pydantic 모델링, 설정 외부화입니다. 이 변경 사항들이 정상적으로 동작하는지, 특히 동시성 환경에서의 안정성과 캐시의 유효성(업데이트 후 무효화 및 갱신)을 집중적으로 검증해 주십시오. 테스트 케이스 실행 및 결과 회신 부탁드립니다.\",\n  \"assignee\": \"dev_qa\"\n}\n</next_sprint>",
