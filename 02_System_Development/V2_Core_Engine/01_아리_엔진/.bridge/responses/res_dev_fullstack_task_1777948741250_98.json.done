  "text": "`src/main/resources/application.yml`\n```yaml\n# ===============================================\n# MyCrew MFA Service Configuration\n# ===============================================\nmfa:\n  service:\n    # [수정] MFA 코드 유효 시간 오차 (초). DEV_ADVISOR 리뷰 반영\n    clock-skew-seconds: 15\n    # [수정] Redis에 MFA 관련 키 저장 시 TTL (초). DEV_ADVISOR 리뷰 반영\n    redis-ttl-seconds: 300\n  rate-limiting:\n    # [수정] Redis 기반 분산 Rate Limiting 활성화. DEV_ADVISOR 리뷰 반영\n    redis:\n      enabled: true\n    # 사용자별 분당 요청 제한 횟수\n    requests-per-minute: 10\n\n# Spring Boot Actuator\nmanagement:\n  endpoints:\n    web:\n      exposure:\n        include: \"health,info,prometheus\"\n\n# AWS KMS\naws:\n  kms:\n    key-id: \"alias/mycrew-mfa-key\"\n    region: \"ap-northeast-2\"\n```\n\n`src/main/java/com/mycrew/auth/service/MfaService.java`\n```java\npackage com.mycrew.auth.service;\n\nimport com.mycrew.auth.exception.MfaDecryptionException;\nimport com.mycrew.auth.exception.MfaVerificationException;\nimport dev.samstevens.totp.code.*;\nimport dev.samstevens.totp.qr.QrData;\nimport dev.samstevens.totp.qr.QrGenerator;\nimport dev.samstevens.totp.secret.DefaultSecretGenerator;\nimport dev.samstevens.totp.secret.SecretGenerator;\nimport dev.samstevens.totp.time.SystemTimeProvider;\nimport dev.samstevens.totp.time.TimeProvider;\nimport lombok.RequiredArgsConstructor;\nimport lombok.extern.slf4j.Slf4j;\nimport org.springframework.beans.factory.annotation.Value;\nimport org.springframework.data.redis.core.StringRedisTemplate;\nimport org.springframework.stereotype.Service;\nimport software.amazon.awssdk.core.SdkBytes;\nimport software.amazon.awssdk.services.kms.KmsClient;\nimport software.amazon.awssdk.services.kms.model.DecryptRequest;\nimport software.amazon.awssdk.services.kms.model.KmsException;\n\nimport java.util.Base64;\nimport java.util.concurrent.TimeUnit;\n\n@Slf4j\n@Service\n@RequiredArgsConstructor\npublic class MfaService {\n\n    private final KmsClient kmsClient;\n    private final StringRedisTemplate redisTemplate;\n\n    // [수정] 설정값을 application.yml에서 주입받도록 변경. DEV_ADVISOR 리뷰 반영\n    @Value(\"${mfa.service.clock-skew-seconds}\")\n    private long clockSkewSeconds;\n\n    @Value(\"${mfa.service.redis-ttl-seconds}\")\n    private long redisTtlSeconds;\n\n    @Value(\"${aws.kms.key-id}\")\n    private String kmsKeyId;\n\n    public String generateNewSecret() {\n        SecretGenerator secretGenerator = new DefaultSecretGenerator();\n        return secretGenerator.generate();\n    }\n\n    public boolean verifyCode(String encryptedSecret, String code) {\n        String secret = decryptSecret(encryptedSecret);\n        TimeProvider timeProvider = new SystemTimeProvider();\n        CodeGenerator codeGenerator = new DefaultCodeGenerator(HashingAlgorithm.SHA1, 6);\n        CodeVerifier verifier = new DefaultCodeVerifier(codeGenerator, timeProvider);\n        \n        // [수정] 하드코딩된 값을 설정값으로 대체\n        verifier.setTimePeriod(30);\n        verifier.setAllowedTimePeriodDiscrepancy(TimeUnit.SECONDS.toMillis(clockSkewSeconds) / 30000); // discrepancy is in periods\n\n        return verifier.isValidCode(secret, code);\n    }\n    \n    private String decryptSecret(String encryptedSecret) {\n        try {\n            SdkBytes ciphertextBlob = SdkBytes.fromByteArray(Base64.getDecoder().decode(encryptedSecret));\n            DecryptRequest decryptRequest = DecryptRequest.builder()\n                    .keyId(kmsKeyId)\n                    .ciphertextBlob(ciphertextBlob)\n                    .build();\n\n            return kmsClient.decrypt(decryptRequest).plaintext().asUtf8String();\n        // [수정] KMS 복호화 실패 시 구체적인 예외 처리 로직 추가. DEV_ADVISOR 리뷰 반영\n        } catch (KmsException e) {\n            log.error(\"KMS Decryption failed for user.\", e);\n            throw new MfaDecryptionException(\"Failed to decrypt MFA secret.\", e);\n        } catch (Exception e) {\n            log.error(\"An unexpected error occurred during MFA secret decryption.\", e);\n            throw new MfaDecryptionException(\"Unexpected error during MFA secret decryption.\", e);\n        }\n    }\n}\n```\n\n`src/main/java/com/mycrew/auth/controller/MfaController.java`\n```java\npackage com.mycrew.auth.controller;\n\nimport com.mycrew.auth.service.MfaService;\nimport io.github.bucket4j.Bandwidth;\nimport io.github.bucket4j.Bucket;\nimport io.github.bucket4j.Refill;\nimport io.github.bucket4j.distributed.proxy.ProxyManager;\nimport jakarta.servlet.http.HttpServletRequest;\nimport lombok.RequiredArgsConstructor;\nimport org.springframework.beans.factory.annotation.Value;\nimport org.springframework.http.HttpStatus;\nimport org.springframework.http.ResponseEntity;\nimport org.springframework.security.core.context.SecurityContextHolder;\nimport org.springframework.web.bind.annotation.PostMapping;\nimport org.springframework.web.bind.annotation.RequestMapping;\nimport org.springframework.web.bind.annotation.RestController;\nimport org.springframework.web.server.ResponseStatusException;\n\nimport java.time.Duration;\n\n@RestController\n@RequestMapping(\"/api/v1/mfa\")\n@RequiredArgsConstructor\npublic class MfaController {\n\n    private final MfaService mfaService;\n    // [수정] 분산 환경을 위한 Redis 기반 ProxyManager 주입. DEV_ADVISOR 리뷰 반영\n    // Bucket4j-spring-boot-starter가 jcache-redis 의존성을 통해 자동 구성\n    private final ProxyManager<String> buckets;\n\n    @Value(\"${mfa.rate-limiting.requests-per-minute}\")\n    private int requestsPerMinute;\n\n    @PostMapping(\"/verify\")\n    public ResponseEntity<Void> verify(HttpServletRequest request, String code, String encryptedSecret) {\n        // [수정] 분산 환경에 맞는 Rate Limiting 적용\n        Bucket bucket = resolveBucket(request);\n        if (!bucket.tryConsume(1)) {\n            throw new ResponseStatusException(HttpStatus.TOO_MANY_REQUESTS, \"You have exhausted your API request quota\");\n        }\n\n        boolean isVerified = mfaService.verifyCode(encryptedSecret, code);\n        if (!isVerified) {\n            return ResponseEntity.status(HttpStatus.UNAUTHORIZED).build();\n        }\n        return ResponseEntity.ok().build();\n    }\n    \n    // [수정] Rate Limiting을 위한 Bucket 해석 로직. DEV_ADVISOR 리뷰 반영\n    private Bucket resolveBucket(HttpServletRequest request) {\n        String key = resolveKey(request);\n        return buckets.builder().build(key, () -> Bandwidth.classic(requestsPerMinute, Refill.greedy(requestsPerMinute, Duration.ofMinutes(1))));\n    }\n\n    // [수정] 사용자 ID 또는 IP 기반으로 Rate Limiting 키를 동적으로 생성. DEV_ADVISOR 리뷰 반영\n    private String resolveKey(HttpServletRequest request) {\n        var authentication = SecurityContextHolder.getContext().getAuthentication();\n        // 인증된 사용자인 경우 사용자 ID를 키로 사용\n        if (authentication != null && authentication.isAuthenticated() && !\"anonymousUser\".equals(authentication.getPrincipal())) {\n            return authentication.getName();\n        }\n        // 비인증 사용자인 경우 IP 주소를 키로 사용\n        return request.getRemoteAddr();\n    }\n}\n```\n\n<next_sprint>\n{\n  \"title\": \"MFA 기능 개선 코드 QA 요청\",\n  \"content\": \"DEV_ADVISOR의 코드 리뷰 사항을 반영하여 MFA 관련 코드를 수정했습니다. (1) 설정 외부화, (2) 예외 처리 강화, (3) 분산 환경 Rate Limiting 적용, (4) Rate Limiting 키 세분화가 주요 변경점입니다. 기능이 의도대로 동작하는지, 엣지 케이스에서 문제는 없는지 QA 부탁드립니다. 수정된 파일: `MfaService.java`, `MfaController.java`, `application.yml`\",\n  \"assignee\": \"dev_qa\"\n}\n</next_sprint>",
