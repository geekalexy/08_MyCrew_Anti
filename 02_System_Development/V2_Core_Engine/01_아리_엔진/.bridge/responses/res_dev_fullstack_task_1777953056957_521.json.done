  "requestedModel": "anti-gemini-3.1-pro-high",
  "text": "```python\n# src/core/context_manager.py\n\nimport time\nfrom typing import Dict, Any, Tuple\n\n# --- Custom Exceptions ---\nclass ContextError(Exception):\n    \"\"\"Base exception for context management errors.\"\"\"\n    pass\n\nclass ContextNotFoundError(ContextError):\n    \"\"\"Raised when context for a specific user/project is not found.\"\"\"\n    pass\n\nclass DataSourceConnectionError(ContextError):\n    \"\"\"Raised when the primary data source is unavailable.\"\"\"\n    pass\n\n\n# --- Context Manager Implementation ---\nclass ContextManager:\n    \"\"\"\n    Manages and provides contextual information for AI agents.\n    Implements an in-memory caching layer to reduce latency and load on the primary data source.\n    \"\"\"\n\n    def __init__(self, cache_ttl: int = 3600):\n        \"\"\"\n        Initializes the ContextManager.\n\n        Args:\n            cache_ttl (int): Time-to-live for cache entries in seconds. Default is 1 hour.\n        \"\"\"\n        self._cache: Dict[Tuple[str, str], Dict[str, Any]] = {}\n        self._cache_timestamps: Dict[Tuple[str, str], float] = {}\n        self.cache_ttl = cache_ttl\n\n    def _get_cache_key(self, user_id: str, project_id: str) -> Tuple[str, str]:\n        \"\"\"Generates a standardized cache key.\"\"\"\n        return (user_id, project_id)\n\n    def _is_cache_valid(self, key: Tuple[str, str]) -> bool:\n        \"\"\"Checks if a cache entry is still valid based on its timestamp.\"\"\"\n        if key not in self._cache_timestamps:\n            return False\n        age = time.time() - self._cache_timestamps[key]\n        return age < self.cache_ttl\n\n    def _load_context_from_db(self, user_id: str, project_id: str) -> Dict[str, Any]:\n        \"\"\"\n        Simulates loading context from a primary data source (e.g., a database).\n        This is a placeholder for the actual database query logic.\n        \"\"\"\n        print(f\"--- DB HIT: Loading context for user '{user_id}', project '{project_id}' ---\")\n        \n        # Simulating potential DB connection issues\n        # import random\n        # if random.random() < 0.1: # 10% chance of failure\n        #     raise DataSourceConnectionError(\"Failed to connect to the context database.\")\n\n        # Dummy data representing our database records\n        DUMMY_DB = {\n            (\"user_alex_01\", \"mycrew_internal\"): {\n                \"project_name\": \"MyCrew Internal Dogfooding\",\n                \"agents\": [\"ari\", \"luca\", \"nova\", \"pico\", \"lily\", \"lumi\"],\n                \"database_uri\": \"mongodb://prod.mycrew.io/internal\",\n                \"access_level\": \"admin\"\n            },\n            (\"user_beta_02\", \"project_x\"): {\n                \"project_name\": \"Project X\",\n                \"agents\": [\"agent_a\", \"agent_b\"],\n                \"database_uri\": \"mongodb://prod.mycrew.io/project_x\",\n                \"access_level\": \"user\"\n            }\n        }\n\n        key = (user_id, project_id)\n        if key in DUMMY_DB:\n            # Simulate network latency\n            time.sleep(0.5)\n            return DUMMY_DB[key]\n        else:\n            raise ContextNotFoundError(f\"Context not found for user '{user_id}' and project '{project_id}'.\")\n\n    def get_context(self, user_id: str, project_id: str) -> Dict[str, Any]:\n        \"\"\"\n        Retrieves the context for a given user and project.\n\n        It first checks the local cache. If a valid entry is found, it's returned.\n        Otherwise, it fetches the context from the primary data source,\n        updates the cache, and then returns the data.\n\n        Args:\n            user_id (str): The ID of the user.\n            project_id (str): The ID of the project.\n\n        Returns:\n            Dict[str, Any]: The contextual data for the session.\n\n        Raises:\n            ContextNotFoundError: If no context is found for the given IDs.\n            DataSourceConnectionError: If the underlying data source is unreachable.\n        \"\"\"\n        cache_key = self._get_cache_key(user_id, project_id)\n\n        # 1. Check cache first\n        if cache_key in self._cache and self._is_cache_valid(cache_key):\n            print(f\"--- CACHE HIT: Found context for user '{user_id}', project '{project_id}' ---\")\n            return self._cache[cache_key]\n\n        # 2. If not in cache or expired, load from data source\n        print(f\"--- CACHE MISS: Fetching context for user '{user_id}', project '{project_id}' ---\")\n        try:\n            context_data = self._load_context_from_db(user_id, project_id)\n            \n            # 3. Update cache\n            self._cache[cache_key] = context_data\n            self._cache_timestamps[cache_key] = time.time()\n            print(f\"--- CACHE SET: Stored context for user '{user_id}', project '{project_id}' ---\")\n            \n            return context_data\n        \n        except (ContextNotFoundError, DataSourceConnectionError) as e:\n            print(f\"ERROR: {e}\")\n            raise # Re-raise the exception to be handled by the caller\n\n# --- Example Usage ---\nif __name__ == '__main__':\n    manager = ContextManager(cache_ttl=10) # Short TTL for demonstration\n\n    print(\"--- First Request (Alex, MyCrew) ---\")\n    context1 = manager.get_context(\"user_alex_01\", \"mycrew_internal\")\n    print(\"Context Received:\", context1)\n    print(\"\\n\" + \"=\"*50 + \"\\n\")\n\n    print(\"--- Second Request (Alex, MyCrew) - Should be from cache ---\")\n    context2 = manager.get_context(\"user_alex_01\", \"mycrew_internal\")\n    print(\"Context Received:\", context2)\n    print(\"\\n\" + \"=\"*50 + \"\\n\")\n\n    print(\"--- First Request (Beta User, Project X) ---\")\n    context3 = manager.get_context(\"user_beta_02\", \"project_x\")\n    print(\"Context Received:\", context3)\n    print(\"\\n\" + \"=\"*50 + \"\\n\")\n\n    print(\"--- Request for Non-existent Context ---\")\n    try:\n        manager.get_context(\"user_unknown_99\", \"project_z\")\n    except ContextNotFoundError as e:\n        print(f\"Successfully caught expected error: {e}\")\n    print(\"\\n\" + \"=\"*50 + \"\\n\")\n    \n    print(f\"--- Waiting for cache to expire ({manager.cache_ttl} seconds) ---\")\n    time.sleep(11)\n    print(\"\\n\" + \"=\"*50 + \"\\n\")\n    \n    print(\"--- Third Request (Alex, MyCrew) - Should be a DB hit again ---\")\n    context4 = manager.get_context(\"user_alex_01\", \"mycrew_internal\")\n    print(\"Context Received:\", context4)\n\n```\n<next_sprint>\n{\n  \"title\": \"ContextManager 모듈 코드 리뷰 요청\",\n  \"content\": \"`docs/technical/context_management.md` 사양에 따라 `src/core/context_manager.py`에 컨텍스트 관리 모듈 초기 구현을 완료했습니다. 캐싱 로직, 예외 처리, 전반적인 구조에 대한 검토를 요청드립니다.\",\n  \"assignee\": \"dev_advisor\"\n}\n</next_sprint>",
