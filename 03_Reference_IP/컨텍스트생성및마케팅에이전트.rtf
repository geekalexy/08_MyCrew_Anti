\cb3 \uc0\u48372 \u46020 \u47197  \u54644  \u48372 \u44192 \u49845 \u45768 \u45796 . \u45348 . \u44536 \u47100  \u50668 \u47084 \u48516  \u54632 \u44760 \u44032  \u48372 \u49884 \u51424 . \u45348 . \u44536 \u47084 \u47732  \u53364 \u47196 \u46300  \u53076 \u46300 \u47484  \u50612  \u50676 \u46020 \u47197  \u54644 \cb1 \
