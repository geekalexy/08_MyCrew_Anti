  "htmlCode": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Socian Problem Card</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=Noto+Sans+KR:wght@400;700;900&display=swap\" rel=\"stylesheet\">\n    <style>\n        /* CSS Reset */\n        body, html {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Inter', sans-serif; /* Default, will be overridden for KR */\n            display: flex; /* To center the card in browser view */\n            justify-content: center;\n            align-items: center;\n            min-height: 100vh;\n            background-color: #f0f0f0; /* Neutral background for browser preview */\n        }\n\n        /* Main Card Container */\n        .card-container {\n            width: 1080px;\n            height: 1080px;\n            background: linear-gradient(135deg, #1A1A2E 0%, #141428 100%); /* Dark gradient using brand color and a slightly darker shade */\n            display: flex;\n            flex-direction: column;\n            justify-content: space-between;\n            align-items: center;\n            padding: 80px; /* Overall padding for content */\n            box-sizing: border-box;\n            position: relative;\n            overflow: hidden; /* Ensure decorative elements don't spill */\n            border-radius: 20px; /* Slightly rounded corners for premium feel */\n            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5); /* Deep shadow for depth */\n        }\n\n        /* Decorative glowing elements */\n        .card-container::before,\n        .card-container::after {\n            content: '';\n            position: absolute;\n            border-radius: 50%;\n            filter: blur(80px);\n            z-index: 0;\n        }\n\n        .card-container::before {\n            top: -100px;\n            left: -100px;\n            width: 400px;\n            height: 400px;\n            background: radial-gradient(circle, rgba(233, 69, 96, 0.3) 0%, rgba(26, 26, 46, 0) 70%); /* Accent color glow */\n        }\n\n        .card-container::after {\n            bottom: -100px;\n            right: -100px;\n            width: 500px;\n            height: 500px;\n            background: radial-gradient(circle, rgba(233, 69, 96, 0.2) 0%, rgba(26, 26, 46, 0) 70%); /* Accent color glow */\n            filter: blur(100px);\n        }\n\n        /* Content Wrapper to ensure z-index and proper layout */\n        .content-wrapper {\n            position: relative;\n            z-index: 1; /* Bring content above decorative blurs */\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            text-align: center;\n            height: 100%; /* Take full height of parent (padded area) */\n            width: 100%; /* Take full width of parent (padded area) */\n        }\n\n        .headline-group {\n            display: flex;\n            flex-direction: column;\n            gap: 40px; /* Space between the two main lines of text */\n            margin-bottom: 80px; /* Space below headlines before brand name */\n        }\n\n        .headline-1 {\n            font-family: 'Noto Sans KR', sans-serif;\n            font-weight: 900; /* Extra bold */\n            font-size: 88px; /* Large for impact */\n            color: #FFFFFF; /* White for strong contrast on dark background */\n            line-height: 1.2;\n            text-shadow: 0 8px 15px rgba(0, 0, 0, 0.4); /* Soft text shadow */\n            margin: 0;\n        }\n\n        .headline-2 {\n            font-family: 'Noto Sans KR', sans-serif;\n            font-weight: 900;\n            font-size: 96px; /* Even larger for the punchline */\n            color: #E94560; /* Brand accent color for emphasis */\n            line-height: 1.2;\n            text-shadow: 0 8px 15px rgba(0, 0, 0, 0.4);\n            margin: 0;\n            position: relative;\n            padding-bottom: 15px; /* Space for the decorative underline */\n        }\n\n        .headline-2::after {\n            content: '';\n            position: absolute;\n            left: 50%;\n            transform: translateX(-50%);\n            bottom: 0;\n            width: 80%; /* Underline width */\n            height: 12px; /* Underline thickness */\n            background: linear-gradient(90deg, transparent 0%, #E94560 50%, transparent 100%); /* Gradient underline */\n            border-radius: 6px;\n            opacity: 0.8;\n        }\n\n        .brand-name {\n            font-family: 'Inter', sans-serif;\n            font-weight: 900; /* Bold for brand name */\n            font-size: 48px;\n            color: rgba(255, 255, 255, 0.7); /* Slightly subdued white for elegance */\n            letter-spacing: 5px; /* Spaced out for a premium feel */\n            margin-top: auto; /* Pushes the brand name to the bottom */\n            text-shadow: 0 2px 5px rgba(0, 0, 0, 0.3);\n        }\n    </style>\n</head>\n<body>\n    <div class=\"card-container\" data-lumi-id=\"lumi-1\">\n        <div class=\"content-wrapper\" data-lumi-id=\"lumi-2\">\n            <div class=\"headline-group\" data-lumi-id=\"lumi-3\">\n                <h1 class=\"headline-1\" data-lumi-id=\"lumi-4\">\n                    어제까지 90% 팔아치운 한국인들,\n                </h1>\n                <p class=\"headline-2\" data-lumi-id=\"lumi-5\">\n                    오늘 땅을 치며 후회 중입니다.\n                </p>\n            </div>\n            <span class=\"brand-name\" data-lumi-id=\"lumi-6\">\n                SOCIAN\n            </span>\n        </div>\n    </div>\n</body>\n</html>",
